---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";

const base = import.meta.env.BASE_URL;
const catalogHref = `${base}categorias/`;
const yapeQr = `${base}pagos/qr-yape_1.webp`;
const yapeLogo = `${base}icons/Yape_peru_logotype.svg`;
const whatsappIcon = `${base}icons/icon-whastapp.svg`;
---

<BaseLayout
	title="Carrito | TAQTO"
	description="Revisa tu carrito y completa tu pedido con TAQTO."
>
	<Header />

	<main class="cart-page">
		<nav class="cart-breadcrumbs" aria-label="Migas de pan">
			<a href={base}>Inicio</a>
			<span aria-hidden="true">/</span>
			<span>Carrito</span>
		</nav>

		<div class="checkout-shell">
			<ol class="cart-steps-indicator" data-steps-indicator>
				<li data-step-indicator="1" class="is-active">
					<span>1</span> Carrito
				</li>
				<li data-step-indicator="2">
					<span>2</span> Datos de envío
				</li>
				<li data-step-indicator="3">
					<span>3</span> Pago
				</li>
			</ol>

			<!-- PASO 1: CARRITO -->
			<section class="cart-step is-active" data-step="1">
				<div class="cart-items" id="cart-items" data-cart-items></div>

				<div class="cart-empty" id="cart-empty" hidden>
					<p>Tu carrito está vacío.</p>
					<a href={catalogHref}>Ver catálogo</a>
				</div>

				<div class="cart-summary">
					<div class="cart-summary__row">
						<span>Subtotal</span>
						<strong id="cart-subtotal">S/ 0.00</strong>
					</div>
				</div>

				<div class="cart-step-actions">
					<a class="cart-secondary-button" href={catalogHref}>
						Seguir comprando
					</a>

					<button
						type="button"
						class="cart-primary-button"
						id="go-to-step-2"
						disabled
					>
						Continuar con mis datos
					</button>
				</div>
			</section>

			<!-- PASO 2: DATOS DE ENVIO -->
			<section class="cart-step" data-step="2" hidden>
				<div class="checkout-grid">
					<form class="shipping-form" id="shipping-form">
						<div class="shipping-form__grid">
							<label class="shipping-field">
								<span>Nombres</span>
								<input
									type="text"
									name="firstName"
									required
									autocomplete="given-name"
								/>
							</label>

							<label class="shipping-field">
								<span>Apellidos</span>
								<input
									type="text"
									name="lastName"
									required
									autocomplete="family-name"
								/>
							</label>

							<label class="shipping-field">
								<span>Correo</span>
								<input
									type="email"
									name="email"
									required
									autocomplete="email"
								/>
							</label>

							<label class="shipping-field">
								<span>Número</span>
								<div class="phone-input">
									<span class="phone-input__prefix">
										<svg
											class="phone-input__flag"
											viewBox="0 0 3 2"
											aria-hidden="true"
										>
											<rect
												width="3"
												height="2"
												fill="#fff"></rect>
											<rect
												width="1"
												height="2"
												fill="#D91023"></rect>
											<rect
												x="2"
												width="1"
												height="2"
												fill="#D91023"></rect>
										</svg>
										+51
									</span>

									<input
										type="tel"
										name="phone"
										required
										pattern="9[0-9]{8}"
										maxlength="9"
										inputmode="numeric"
										placeholder="9XXXXXXXX"
										title="Número de celular peruano: 9 dígitos, empieza con 9."
										autocomplete="tel-national"
									/>
								</div>
							</label>

							<label class="shipping-field">
								<span>Departamento</span>
								<select
									id="select-departamento"
									name="departamento"
									required
								></select>
							</label>

							<label class="shipping-field">
								<span>Provincia</span>
								<select
									id="select-provincia"
									name="provincia"
									required
									disabled
								></select>
							</label>

							<label class="shipping-field">
								<span>Distrito</span>
								<select
									id="select-distrito"
									name="distrito"
									required
									disabled
								></select>
							</label>

							<label class="shipping-field shipping-field--full">
								<span>Dirección</span>
								<input
									type="text"
									name="direccion"
									required
									placeholder="Av./Jr./Calle, número, urbanización"
									autocomplete="street-address"
								/>
							</label>

							<label class="shipping-field shipping-field--full">
								<span>Referencia (opcional)</span>
								<input
									type="text"
									name="referencia"
									placeholder="Ej: frente al parque, edificio azul"
								/>
							</label>
						</div>

						<p
							class="shipping-method-preview"
							id="shipping-method-preview"
						>
							Elige tu departamento para ver el método y costo
							de envío.
						</p>

						<label class="shipping-field shipping-field--full">
							<span>Mensaje para la tarjeta de regalo (opcional)</span>
							<textarea
								name="giftMessage"
								rows="3"
								placeholder="Escribe aquí el mensaje que quieres incluir en la tarjeta de regalo"
							></textarea>
						</label>
					</form>

					<aside class="order-aside">
						<p class="order-aside__label">Tu pedido</p>

						<div
							class="order-aside__products"
							id="mini-products-summary"
						></div>

						<div class="order-aside__totals">
							<div class="order-summary__row">
								<span>Subtotal</span>
								<strong id="mini-subtotal">S/ 0.00</strong>
							</div>

							<div class="order-summary__row">
								<span id="mini-shipping-label">Envío</span>
								<strong id="mini-shipping-amount">—</strong>
							</div>

							<div
								class="order-summary__row order-summary__row--total"
							>
								<span>Total</span>
								<strong id="mini-total">S/ 0.00</strong>
							</div>
						</div>
					</aside>
				</div>

				<div class="cart-step-actions">
					<button
						type="button"
						class="cart-secondary-button"
						data-go-step="1"
					>
						Volver al carrito
					</button>

					<button
						type="button"
						class="cart-primary-button"
						id="go-to-step-3"
					>
						Continuar al pago
					</button>
				</div>
			</section>

			<!-- PASO 3: PAGO -->
			<section class="cart-step" data-step="3" hidden>
				<div class="checkout-grid">
					<div class="order-summary">
						<div class="order-summary__block">
							<p class="order-summary__label">Datos del cliente</p>
							<dl
								class="order-summary__list"
								id="order-customer-summary"
							></dl>
						</div>

						<div class="order-summary__block">
							<p class="order-summary__label">Productos</p>
							<div
								class="order-summary__products"
								id="order-products-summary"
							></div>
						</div>

						<div class="order-summary__totals" id="order-totals">
							<div class="order-summary__row">
								<span>Subtotal</span>
								<strong id="order-subtotal">S/ 0.00</strong>
							</div>

							<div class="order-summary__row">
								<span id="order-shipping-label">Envío</span>
								<strong id="order-shipping-amount">S/ 0.00</strong>
							</div>

							<div
								class="order-summary__row order-summary__row--total"
							>
								<span>Total</span>
								<strong id="order-total">S/ 0.00</strong>
							</div>
						</div>
					</div>

					<aside class="payment-aside">
						<p class="order-aside__label">
							Elige cómo pagar
						</p>

						<p class="order-confirm__hint">
							Al elegir un método, registramos tu
							pedido en nuestro sistema y te damos un
							código para confirmar el pago.
						</p>

						<div class="payment-options">
							<button
								type="button"
								class="payment-option payment-option--whatsapp"
								id="pay-whatsapp"
							>
								<img src={whatsappIcon} alt="" width="26" height="26" />
								<span>
									<strong>Pedir por WhatsApp</strong>
									<small>Te confirmamos tu pedido por chat</small>
								</span>
							</button>

							<button
								type="button"
								class="payment-option payment-option--yape"
								id="pay-yape"
							>
								<img
									class="payment-option__yape-logo"
									src={yapeLogo}
									alt="Yape"
									width="52"
									height="28"
								/>
								<span>
									<strong>Pagar con Yape</strong>
									<small>Yapea y envíanos tu comprobante</small>
								</span>
							</button>
						</div>

						<p
							class="order-confirm__error"
							id="order-confirm-error"
							role="alert"
							hidden
						></p>

						<div
							class="order-created"
							id="order-created-block"
							hidden
						>
							<p class="order-created__label">
								¡Pedido creado!
							</p>

							<p
								class="order-created__code"
								id="order-created-code"
							></p>

							<p class="order-created__hint">
								Guarda este código: lo vas a usar para
								confirmar tu pago.
							</p>
						</div>

						<div class="yape-panel" id="yape-panel" hidden>
							<img
								class="yape-panel__logo"
								src={yapeLogo}
								alt="Yape"
								width="72"
								height="38"
							/>

							<div class="yape-panel__details">
								<p>
									<span>Nombre</span>
									Gianmarco Santillán
								</p>
								<p>
									<span>Número</span>
									977 600 400
								</p>
							</div>

							<div class="yape-panel__qr-frame">
								<img
									class="yape-panel__qr"
									src={yapeQr}
									alt="Código QR de Yape para pagar"
									width="180"
									height="180"
								/>
							</div>

							<a
								class="cart-primary-button"
								id="yape-send-proof"
								target="_blank"
								rel="noopener noreferrer"
							>
								Enviar comprobante
							</a>
						</div>
					</aside>
				</div>

				<div class="cart-step-actions">
					<button
						type="button"
						class="cart-secondary-button"
						data-go-step="2"
					>
						Volver a mis datos
					</button>
				</div>
			</section>
		</div>
	</main>
</BaseLayout>

<script>
	import {
		getCart,
		updateQuantity,
		removeItem,
		onCartUpdated,
		type CartItem,
	} from "../lib/cart";

	import { formatPEN } from "../lib/productPricing";

	import {
		getDepartamentos,
		getProvincias,
		getDistritos,
		getDepartamentoName,
		getProvinciaName,
		getDistritoName,
		isLimaMetropolitana,
		type UbigeoOption,
	} from "../lib/peruUbigeo";

	import {
		WHATSAPP_NUMBER,
		SHIPPING_COST,
	} from "../lib/constants";

	import { supabase } from "../lib/supabase";

	const steps = Array.from(
		document.querySelectorAll<HTMLElement>(
			"[data-step]",
		),
	);

	const stepIndicators = Array.from(
		document.querySelectorAll<HTMLElement>(
			"[data-step-indicator]",
		),
	);

	const goToStep = (stepNumber: number) => {
		steps.forEach((section) => {
			const isActive =
				section.dataset.step === String(stepNumber);

			section.hidden = !isActive;
			section.classList.toggle(
				"is-active",
				isActive,
			);
		});

		stepIndicators.forEach((indicator) => {
			const stepValue = Number(
				indicator.dataset.stepIndicator,
			);

			indicator.classList.toggle(
				"is-active",
				stepValue === stepNumber,
			);

			indicator.classList.toggle(
				"is-complete",
				stepValue < stepNumber,
			);
		});

		window.scrollTo({ top: 0, behavior: "smooth" });
	};

	document
		.querySelectorAll<HTMLButtonElement>(
			"[data-go-step]",
		)
		.forEach((button) => {
			button.addEventListener("click", () => {
				goToStep(
					Number(button.dataset.goStep),
				);
			});
		});

	// ---------- PASO 1: CARRITO ----------

	const cartItemsContainer =
		document.querySelector<HTMLElement>(
			"#cart-items",
		)!;

	const cartEmptyState =
		document.querySelector<HTMLElement>(
			"#cart-empty",
		)!;

	const cartSubtotalLabel =
		document.querySelector<HTMLElement>(
			"#cart-subtotal",
		)!;

	const goToStep2Button =
		document.querySelector<HTMLButtonElement>(
			"#go-to-step-2",
		)!;

	const getCartSubtotal = (items: CartItem[]) =>
		items.reduce(
			(total, item) =>
				total + item.unitPrice * item.quantity,
			0,
		);

	const variantLabelOf = (item: CartItem) =>
		[item.woodTitle, item.sizeTitle]
			.filter(Boolean)
			.join(" · ");

	const renderCartItems = () => {
		const items = getCart();

		cartItemsContainer.innerHTML = "";
		cartEmptyState.hidden = items.length > 0;
		goToStep2Button.disabled = items.length === 0;

		items.forEach((item) => {
			const row = document.createElement("div");
			row.className = "cart-item";

			const variantLabel = variantLabelOf(item);

			row.innerHTML = `
				<div class="cart-item__media">
					${
						item.image
							? `<img src="${item.image}" alt="${item.title}" loading="lazy" />`
							: `<div class="cart-item__placeholder">TAQTO</div>`
					}
				</div>

				<div class="cart-item__content">
					<p class="cart-item__title">${item.title}</p>
					${
						variantLabel
							? `<p class="cart-item__variant">${variantLabel}</p>`
							: ""
					}
					<p class="cart-item__price">${formatPEN(item.unitPrice)} c/u</p>
				</div>

				<div class="cart-item__actions">
					<input
						type="number"
						min="1"
						step="1"
						class="cart-item__quantity"
						value="${item.quantity}"
						aria-label="Cantidad de ${item.title}"
					/>

					<button
						type="button"
						class="cart-item__remove"
						aria-label="Quitar ${item.title} del carrito"
					>
						Quitar
					</button>
				</div>

				<p class="cart-item__line-total">
					${formatPEN(item.unitPrice * item.quantity)}
				</p>
			`;

			const quantityInput =
				row.querySelector<HTMLInputElement>(
					".cart-item__quantity",
				)!;

			quantityInput.addEventListener(
				"change",
				() => {
					const nextQuantity = Math.max(
						1,
						Math.floor(
							Number(quantityInput.value) || 1,
						),
					);

					updateQuantity(item.id, nextQuantity);
				},
			);

			const removeButton =
				row.querySelector<HTMLButtonElement>(
					".cart-item__remove",
				)!;

			removeButton.addEventListener("click", () => {
				removeItem(item.id);
			});

			cartItemsContainer.appendChild(row);
		});

		cartSubtotalLabel.textContent = formatPEN(
			getCartSubtotal(items),
		);
	};

	renderCartItems();
	onCartUpdated(renderCartItems);

	goToStep2Button.addEventListener("click", () => {
		if (getCart().length === 0) return;
		goToStep(2);
	});

	// ---------- MINI RESUMEN (PASO 2) ----------

	const miniProductsSummary =
		document.querySelector<HTMLElement>(
			"#mini-products-summary",
		)!;

	const miniSubtotalLabel =
		document.querySelector<HTMLElement>(
			"#mini-subtotal",
		)!;

	const miniShippingLabelEl =
		document.querySelector<HTMLElement>(
			"#mini-shipping-label",
		)!;

	const miniShippingAmountLabel =
		document.querySelector<HTMLElement>(
			"#mini-shipping-amount",
		)!;

	const miniTotalLabel =
		document.querySelector<HTMLElement>(
			"#mini-total",
		)!;

	const renderProductLines = (
		container: HTMLElement,
		items: CartItem[],
	) => {
		container.innerHTML = items
			.map((item) => {
				const variant = variantLabelOf(item);

				return `
					<div class="order-summary__product">
						<span>
							${item.title}${variant ? ` — ${variant}` : ""}
							× ${item.quantity}
						</span>
						<strong>${formatPEN(item.unitPrice * item.quantity)}</strong>
					</div>
				`;
			})
			.join("");
	};

	const renderMiniSummary = () => {
		const items = getCart();
		const subtotal = getCartSubtotal(items);

		renderProductLines(miniProductsSummary, items);
		miniSubtotalLabel.textContent = formatPEN(subtotal);

		const departamentoValue =
			departamentoSelect.value;

		if (!departamentoValue) {
			miniShippingLabelEl.textContent = "Envío";
			miniShippingAmountLabel.textContent = "—";
			miniTotalLabel.textContent = formatPEN(subtotal);
			return;
		}

		const isLima = isLimaMetropolitana(
			departamentoValue,
		);

		miniShippingLabelEl.textContent = isLima
			? "Delivery (Lima)"
			: "Envío a agencia";

		miniShippingAmountLabel.textContent =
			formatPEN(SHIPPING_COST);

		miniTotalLabel.textContent = formatPEN(
			subtotal + SHIPPING_COST,
		);
	};

	// ---------- PASO 2: DATOS DE ENVIO ----------

	const shippingForm =
		document.querySelector<HTMLFormElement>(
			"#shipping-form",
		)!;

	const departamentoSelect =
		document.querySelector<HTMLSelectElement>(
			"#select-departamento",
		)!;

	const provinciaSelect =
		document.querySelector<HTMLSelectElement>(
			"#select-provincia",
		)!;

	const distritoSelect =
		document.querySelector<HTMLSelectElement>(
			"#select-distrito",
		)!;

	const shippingMethodPreview =
		document.querySelector<HTMLElement>(
			"#shipping-method-preview",
		)!;

	const populateSelect = (
		select: HTMLSelectElement,
		options: UbigeoOption[],
		placeholder: string,
	) => {
		select.innerHTML = "";

		const placeholderOption =
			document.createElement("option");

		placeholderOption.value = "";
		placeholderOption.textContent = placeholder;
		placeholderOption.disabled = true;
		placeholderOption.selected = true;

		select.appendChild(placeholderOption);

		options.forEach((option) => {
			const optionEl =
				document.createElement("option");

			optionEl.value = option.id;
			optionEl.textContent = option.name;
			select.appendChild(optionEl);
		});
	};

	const getShippingLabel = () => {
		if (!departamentoSelect.value) {
			return "Elige tu departamento para ver el método y costo de envío.";
		}

		const isLima = isLimaMetropolitana(
			departamentoSelect.value,
		);

		return isLima
			? `Delivery a domicilio (Lima Metropolitana) — ${formatPEN(SHIPPING_COST)}`
			: `Envío a agencia en tu ciudad — ${formatPEN(SHIPPING_COST)}`;
	};

	const updateShippingPreview = () => {
		shippingMethodPreview.textContent =
			getShippingLabel();

		renderMiniSummary();
	};

	populateSelect(
		departamentoSelect,
		getDepartamentos(),
		"Selecciona un departamento",
	);

	departamentoSelect.addEventListener(
		"change",
		() => {
			const provincias = getProvincias(
				departamentoSelect.value,
			);

			populateSelect(
				provinciaSelect,
				provincias,
				"Selecciona una provincia",
			);

			provinciaSelect.disabled =
				provincias.length === 0;

			populateSelect(
				distritoSelect,
				[],
				"Selecciona una provincia primero",
			);

			distritoSelect.disabled = true;

			updateShippingPreview();
		},
	);

	provinciaSelect.addEventListener("change", () => {
		const distritos = getDistritos(
			provinciaSelect.value,
		);

		populateSelect(
			distritoSelect,
			distritos,
			"Selecciona un distrito",
		);

		distritoSelect.disabled =
			distritos.length === 0;
	});

	onCartUpdated(renderMiniSummary);
	renderMiniSummary();

	const goToStep3Button =
		document.querySelector<HTMLButtonElement>(
			"#go-to-step-3",
		)!;

	goToStep3Button.addEventListener("click", () => {
		if (!shippingForm.reportValidity()) return;

		buildOrderSummary();
		goToStep(3);
	});

	// ---------- PASO 3: PAGO ----------

	const orderCustomerSummary =
		document.querySelector<HTMLElement>(
			"#order-customer-summary",
		)!;

	const orderProductsSummary =
		document.querySelector<HTMLElement>(
			"#order-products-summary",
		)!;

	const orderSubtotalLabel =
		document.querySelector<HTMLElement>(
			"#order-subtotal",
		)!;

	const orderShippingLabelEl =
		document.querySelector<HTMLElement>(
			"#order-shipping-label",
		)!;

	const orderShippingAmountLabel =
		document.querySelector<HTMLElement>(
			"#order-shipping-amount",
		)!;

	const orderTotalLabel =
		document.querySelector<HTMLElement>(
			"#order-total",
		)!;

	const getCustomerData = () => {
		const formData = new FormData(shippingForm);

		const departamentoId = String(
			formData.get("departamento") || "",
		);

		const provinciaId = String(
			formData.get("provincia") || "",
		);

		const distritoId = String(
			formData.get("distrito") || "",
		);

		return {
			firstName: String(
				formData.get("firstName") || "",
			),
			lastName: String(
				formData.get("lastName") || "",
			),
			email: String(formData.get("email") || ""),
			phone: `+51 ${String(formData.get("phone") || "")}`,
			departamento:
				getDepartamentoName(departamentoId),
			provincia: getProvinciaName(provinciaId),
			distrito: getDistritoName(distritoId),
			direccion: String(
				formData.get("direccion") || "",
			),
			referencia: String(
				formData.get("referencia") || "",
			),
			giftMessage: String(
				formData.get("giftMessage") || "",
			),
			isLima: isLimaMetropolitana(departamentoId),
		};
	};

	const buildOrderSummary = () => {
		const customer = getCustomerData();
		const items = getCart();
		const subtotal = getCartSubtotal(items);
		const total = subtotal + SHIPPING_COST;

		const shippingLabel = customer.isLima
			? "Delivery a domicilio (Lima Metropolitana)"
			: "Envío a agencia en tu ciudad";

		orderCustomerSummary.innerHTML = `
			<div>
				<dt>Nombre</dt>
				<dd>${customer.firstName} ${customer.lastName}</dd>
			</div>
			<div>
				<dt>Correo</dt>
				<dd>${customer.email}</dd>
			</div>
			<div>
				<dt>Teléfono</dt>
				<dd>${customer.phone}</dd>
			</div>
			<div>
				<dt>Dirección</dt>
				<dd>${customer.direccion}${
					customer.referencia
						? ` (${customer.referencia})`
						: ""
				}</dd>
			</div>
			<div>
				<dt>Ubicación</dt>
				<dd>${customer.distrito}, ${customer.provincia}, ${customer.departamento}</dd>
			</div>
			${
				customer.giftMessage
					? `<div><dt>Tarjeta de regalo</dt><dd>${customer.giftMessage}</dd></div>`
					: ""
			}
		`;

		renderProductLines(orderProductsSummary, items);

		orderSubtotalLabel.textContent =
			formatPEN(subtotal);

		orderShippingLabelEl.textContent = shippingLabel;
		orderShippingAmountLabel.textContent =
			formatPEN(SHIPPING_COST);

		orderTotalLabel.textContent = formatPEN(total);
	};

	const buildWhatsAppOrderMessage = (
		orderCode: string,
	) =>
		`Hola TAQTO, acabo de registrar el pedido ${orderCode}. Quisiera confirmar el pago y la personalización.`;

	const buildWhatsAppReceiptMessage = (
		orderCode: string,
	) =>
		`Hola TAQTO, ya yapeé el pedido ${orderCode}. Adjunto la captura del comprobante.`;

	// ---------- CREAR PEDIDO EN SUPABASE ----------

	let createdOrderCode: string | null = null;
	let orderCreationInFlight = false;

	const orderConfirmError =
		document.querySelector<HTMLElement>(
			"#order-confirm-error",
		)!;

	const orderCreatedBlock =
		document.querySelector<HTMLElement>(
			"#order-created-block",
		)!;

	const orderCreatedCode =
		document.querySelector<HTMLElement>(
			"#order-created-code",
		)!;

	const payWhatsAppButton =
		document.querySelector<HTMLButtonElement>(
			"#pay-whatsapp",
		)!;

	const payYapeButton =
		document.querySelector<HTMLButtonElement>(
			"#pay-yape",
		)!;

	const yapePanel =
		document.querySelector<HTMLElement>(
			"#yape-panel",
		)!;

	const yapeSendProofLink =
		document.querySelector<HTMLAnchorElement>(
			"#yape-send-proof",
		)!;

	const buildOrderItemsPayload = (items: CartItem[]) =>
		items.map((item) => ({
			sanityProductId: item.productId,
			sanityProductSlug: item.slug,
			productName: item.title,
			productSku: item.sku,
			woodName: item.woodTitle || null,
			woodSlug: item.woodSlug || null,
			sizeName: item.sizeTitle || null,
			sizeSlug: item.sizeSlug || null,
			dimensionsLabel: item.dimensionsLabel || null,
			quantity: item.quantity,
			unitPrice: item.unitPrice,
		}));

	const ensureOrderCreated = async (
		paymentMethod: "yape" | "cash_on_delivery",
	): Promise<string | null> => {
		if (createdOrderCode) return createdOrderCode;
		if (orderCreationInFlight) return null;

		const customer = getCustomerData();
		const items = getCart();

		if (items.length === 0) return null;

		const subtotal = getCartSubtotal(items);
		const total = subtotal + SHIPPING_COST;

		orderCreationInFlight = true;
		orderConfirmError.hidden = true;

		payWhatsAppButton.classList.add("is-loading");
		payYapeButton.classList.add("is-loading");

		const { data, error } = await supabase.rpc(
			"create_order",
			{
				p_payment_method: paymentMethod,
				p_delivery_method: customer.isLima
					? "lima_delivery"
					: "province_agency",
				p_customer_first_name: customer.firstName,
				p_customer_last_name: customer.lastName,
				p_customer_email: customer.email,
				p_customer_phone: customer.phone,
				p_delivery_department: customer.departamento,
				p_delivery_province: customer.provincia,
				p_delivery_district: customer.distrito,
				p_delivery_address: customer.direccion,
				p_delivery_reference:
					customer.referencia || null,
				p_customer_notes: customer.giftMessage
					? `Mensaje para la tarjeta de regalo: ${customer.giftMessage}`
					: null,
				p_subtotal: subtotal,
				p_delivery_cost: SHIPPING_COST,
				p_total: total,
				p_items: buildOrderItemsPayload(items),
			},
		);

		orderCreationInFlight = false;
		payWhatsAppButton.classList.remove("is-loading");
		payYapeButton.classList.remove("is-loading");

		if (error || !data) {
			orderConfirmError.textContent =
				"No pudimos registrar tu pedido. Intenta de nuevo o escríbenos directo por WhatsApp.";

			orderConfirmError.hidden = false;
			return null;
		}

		createdOrderCode = data as string;
		orderCreatedBlock.hidden = false;
		orderCreatedCode.textContent = createdOrderCode;

		return createdOrderCode;
	};

	payWhatsAppButton.addEventListener(
		"click",
		async () => {
			const code = await ensureOrderCreated(
				"cash_on_delivery",
			);

			if (!code) return;

			const message = encodeURIComponent(
				buildWhatsAppOrderMessage(code),
			);

			window.open(
				`https://wa.me/${WHATSAPP_NUMBER}?text=${message}`,
				"_blank",
				"noopener,noreferrer",
			);

			orderCreatedBlock.scrollIntoView({
				behavior: "smooth",
				block: "center",
			});
		},
	);

	payYapeButton.addEventListener("click", async () => {
		const code = await ensureOrderCreated("yape");

		if (!code) return;

		yapePanel.hidden = false;

		const message = encodeURIComponent(
			buildWhatsAppReceiptMessage(code),
		);

		yapeSendProofLink.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${message}`;

		yapePanel.scrollIntoView({
			behavior: "smooth",
			block: "center",
		});
	});
</script>

