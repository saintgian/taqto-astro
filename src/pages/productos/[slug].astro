---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import { PortableText } from "astro-portabletext";
import {
	sanityClient,
	urlForImage,
} from "../../lib/sanity";

import { productDetailQuery } from "../../lib/productDetailQuery";

interface Wood {
	title?: string;
	slug?: string;
	image?: unknown;
}

interface ProductSize {
	title?: string;
	slug?: string;
	dimensionsLabel?: string;
}

interface Variant {
	_key?: string;
	sku?: string;
	price?: number;
	salePrice?: number;
	stockQuantity?: number;
	active?: boolean;
	wood?: Wood;
	size?: ProductSize;
}

interface ProductImage {
	_key?: string;
	alt?: string;
	caption?: string;
	asset?: unknown;
}

interface Product {
	_id: string;
	title: string;
	slug: string;
	sku?: string;
	shortDescription?: string;
	description?: any[];
	productMode?: string;
	gallery?: ProductImage[];
	materials?: string[];
	careInstructions?: string;
	saleStart?: string;
	saleEnd?: string;
	engravingIncluded?: boolean;
	engravingTypes?: string[];
	engravingMaxCharacters?: number;
	personalizationNotes?: string;
	corporateEligible?: boolean;
	metaTitle?: string;
	metaDescription?: string;

	category?: {
		title?: string;
		slug?: string;
	};

	subcategory?: {
		title?: string;
		slug?: string;
	};

	uniqueProduct?: {
		sku?: string;
		price?: number;
		salePrice?: number;
		stockQuantity?: number;
		available?: boolean;
		wood?: Wood;
		size?: ProductSize;
	};

	variants?: Variant[];
}

export async function getStaticPaths() {
	const products =
		await sanityClient.fetch<Product[]>(
			productDetailQuery,
		);

	return products.map((product) => ({
		params: {
			slug: product.slug,
		},

		props: {
			product,
		},
	}));
}

const { product } = Astro.props as {
	product: Product;
};

const base = import.meta.env.BASE_URL;

const categoryHref = product.category?.slug
	? `${base}categorias/${product.category.slug}/`
	: `${base}categorias/`;

const contactHref = `${base}contactanos/`;

const activeVariants = (product.variants || []).filter(
	(variant) => variant.active !== false,
);

const uniqueWoods = Array.from(
	new Map(
		activeVariants
			.filter((variant) => variant.wood?.slug)
			.map((variant) => [
				variant.wood?.slug,
				variant.wood,
			]),
	).values(),
).filter(Boolean) as Wood[];

const uniqueSizes = Array.from(
	new Map(
		activeVariants
			.filter((variant) => variant.size?.slug)
			.map((variant) => [
				variant.size?.slug,
				variant.size,
			]),
	).values(),
).filter(Boolean) as ProductSize[];

const hasWoodSelector =
	product.productMode === "wood" ||
	product.productMode === "woodSize";

const hasSizeSelector =
	product.productMode === "size" ||
	product.productMode === "woodSize";

const saleIsActive = (
	saleStart?: string,
	saleEnd?: string,
) => {
	const now = Date.now();

	if (
		saleStart &&
		now < new Date(saleStart).getTime()
	) {
		return false;
	}

	if (
		saleEnd &&
		now > new Date(saleEnd).getTime()
	) {
		return false;
	}

	return true;
};

const currentSaleIsActive = saleIsActive(
	product.saleStart,
	product.saleEnd,
);

const firstVariant =
	product.productMode === "unique"
		? product.uniqueProduct
		: activeVariants[0];

const initialRegularPrice =
	firstVariant?.price ?? 0;

const initialSalePrice =
	currentSaleIsActive
		? firstVariant?.salePrice
		: undefined;

const initialVisiblePrice =
	typeof initialSalePrice === "number"
		? initialSalePrice
		: initialRegularPrice;

const initialStock =
	firstVariant?.stockQuantity ?? 0;

const initialSku =
	product.productMode === "unique"
		? product.sku
		: (firstVariant as Variant)?.sku || product.sku;

const formatPrice = (value: number) =>
	new Intl.NumberFormat("es-PE", {
		style: "currency",
		currency: "PEN",
		minimumFractionDigits: 2,
	}).format(value);

const mainImage = product.gallery?.[0];

const mainImageUrl = mainImage
	? urlForImage(mainImage)
			.width(1200)
			.height(1500)
			.fit("crop")
			.auto("format")
			.url()
	: "";

const mainImageAlt =
	mainImage?.alt ||
	`${product.title} de TAQTO`;

const pageTitle =
	product.metaTitle ||
	`${product.title} | TAQTO`;

const pageDescription =
	product.metaDescription ||
	product.shortDescription ||
	`Conoce ${product.title} de TAQTO.`;

const engravingLabels: Record<string, string> = {
	name: "Nombre",
	phrase: "Frase",
	date: "Fecha",
	logo: "Logotipo",
};

const variantData = activeVariants.map((variant) => ({
	key: variant._key || "",
	woodSlug: variant.wood?.slug || "",
	woodTitle: variant.wood?.title || "",
	sizeSlug: variant.size?.slug || "",
	sizeTitle: variant.size?.title || "",
	dimensions: variant.size?.dimensionsLabel || "",
	sku: variant.sku || product.sku || "",
	price: variant.price || 0,
	salePrice:
		typeof variant.salePrice === "number"
			? variant.salePrice
			: null,
	stock: variant.stockQuantity || 0,
}));

const uniqueProductData =
	product.productMode === "unique"
		? {
				sku:
					product.uniqueProduct?.sku ||
					product.sku ||
					"",
				price: product.uniqueProduct?.price || 0,
				salePrice:
					typeof product.uniqueProduct
						?.salePrice === "number"
						? product.uniqueProduct.salePrice
						: null,
				stock:
					product.uniqueProduct
						?.stockQuantity || 0,
			}
		: null;

const safeVariantJson = JSON.stringify({
	variants: variantData,
	saleActive: currentSaleIsActive,
	productMode: product.productMode || "unique",
	uniqueProduct: uniqueProductData,
	product: {
		slug: product.slug,
		title: product.title,
		image: mainImageUrl,
	},
}).replace(/</g, "\\u003c");
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
>
	<Header />

	<main class="product-page">
		<nav
			class="product-breadcrumbs"
			aria-label="Migas de pan"
		>
			<a href={base}>Inicio</a>
			<span aria-hidden="true">/</span>

			<a href={categoryHref}>
				{product.category?.title || "Tienda"}
			</a>

			<span aria-hidden="true">/</span>

			<span>{product.title}</span>
		</nav>

		<section class="product-hero">
			<div class="product-gallery">
				<div class="product-main-image">
					{
						mainImageUrl ? (
							<img
								id="product-main-image"
								src={mainImageUrl}
								alt={mainImageAlt}
								width="1200"
								height="1500"
								loading="eager"
								decoding="async"
							/>
						) : (
							<div class="product-image-placeholder">
								<span>TAQTO</span>
							</div>
						)
					}
				</div>

				{
					product.gallery &&
					product.gallery.length > 1 && (
						<div
							class="product-thumbnails"
							aria-label="Galería del producto"
						>
							{product.gallery.map(
								(image, index) => {
									const thumbnailUrl =
										urlForImage(image)
											.width(240)
											.height(300)
											.fit("crop")
											.auto("format")
											.url();

									const largeUrl =
										urlForImage(image)
											.width(1200)
											.height(1500)
											.fit("crop")
											.auto("format")
											.url();

									return (
										<button
											class:list={[
												"product-thumbnail",
												{
													"is-active":
														index === 0,
												},
											]}
											type="button"
											data-product-thumbnail
											data-large-image={largeUrl}
											data-image-alt={
												image.alt ||
												product.title
											}
											aria-label={`Ver imagen ${
												index + 1
											}`}
										>
											<img
												src={thumbnailUrl}
												alt=""
												width="240"
												height="300"
												loading="lazy"
											/>
										</button>
									);
								},
							)}
						</div>
					)
				}
			</div>

			<div class="product-information">
				<p class="product-category">
					{product.category?.title || "TAQTO"}
				</p>

				<h1>{product.title}</h1>

				<p class="product-short-description">
					{product.shortDescription}
				</p>

				<div class="product-price-wrapper">
					<p
						class="product-price"
						id="product-price"
					>
						{formatPrice(initialVisiblePrice)}
					</p>

					<p
						class:list={[
							"product-regular-price",
							{
								"is-hidden":
									typeof initialSalePrice !==
									"number",
							},
						]}
						id="product-regular-price"
					>
						{formatPrice(initialRegularPrice)}
					</p>
				</div>

				<div class="product-status">
					<span
						class:list={[
							"product-status__dot",
							{
								"is-out":
									initialStock <= 0,
							},
						]}
						id="product-stock-dot"
					></span>

					<span id="product-stock-label">
						{
							initialStock > 0
								? `${initialStock} unidades disponibles`
								: "Temporalmente agotado"
						}
					</span>
				</div>

				<div class="product-meta">
					<span>SKU</span>
					<strong id="product-sku">
						{initialSku || "Sin SKU"}
					</strong>
				</div>

				{
					hasWoodSelector &&
						uniqueWoods.length > 0 && (
							<fieldset class="product-option-group">
								<legend>Elige la madera</legend>

								<div class="product-option-list">
									{uniqueWoods.map(
										(wood, index) => (
											<button
												class:list={[
													"product-option",
													{
														"is-selected":
															index === 0,
													},
												]}
												type="button"
												data-option-wood
												data-value={wood.slug}
												aria-pressed={
													index === 0
														? "true"
														: "false"
												}
											>
												{wood.title}
											</button>
										),
									)}
								</div>
							</fieldset>
						)
				}

				{
					hasSizeSelector &&
						uniqueSizes.length > 0 && (
							<fieldset class="product-option-group">
								<legend>Elige el tamaño</legend>

								<div class="product-option-list">
									{uniqueSizes.map(
										(size, index) => (
											<button
												class:list={[
													"product-option",
													{
														"is-selected":
															index === 0,
													},
												]}
												type="button"
												data-option-size
												data-value={size.slug}
												aria-pressed={
													index === 0
														? "true"
														: "false"
												}
											>
												<strong>
													{size.title}
												</strong>

												{size.dimensionsLabel && (
													<small>
														{
															size.dimensionsLabel
														}
													</small>
												)}
											</button>
										),
									)}
								</div>
							</fieldset>
						)
				}

				<p
					class="product-variation-message"
					id="product-variation-message"
					aria-live="polite"
				></p>

				<div class="product-personalization">
					<div class="product-personalization__icon">
						<svg
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path d="M12 3 5 7v5c0 4.4 2.8 7.7 7 9 4.2-1.3 7-4.6 7-9V7l-7-4Z"></path>
							<path d="m9 12 2 2 4-5"></path>
						</svg>
					</div>

					<div>
						<strong>
							Grabado láser personalizado gratuito
						</strong>

						<p>
							{
								product.personalizationNotes ||
									"Personaliza tu pieza sin costo adicional."
							}
						</p>
					</div>
				</div>

				<div class="product-quantity-row">
					<div
						class="product-quantity"
						role="group"
						aria-label="Cantidad"
					>
						<button
							type="button"
							class="product-quantity__button"
							data-quantity-decrease
							aria-label="Reducir cantidad"
						>
							−
						</button>

						<input
							type="number"
							class="product-quantity__input"
							id="product-quantity-input"
							min="1"
							step="1"
							value="1"
							inputmode="numeric"
							aria-label="Cantidad"
						/>

						<button
							type="button"
							class="product-quantity__button"
							data-quantity-increase
							aria-label="Aumentar cantidad"
						>
							+
						</button>
					</div>

					<button
						type="button"
						class:list={[
							"product-add-to-cart",
							{
								"is-disabled":
									initialStock <= 0,
							},
						]}
						id="product-add-to-cart"
					>
						<span id="product-add-to-cart-label">
							Agregar al carrito
						</span>
					</button>
				</div>

				<a
					class:list={[
						"product-contact-button",
						{
							"is-disabled":
								initialStock <= 0,
						},
					]}
					id="product-contact-button"
					href={contactHref}
				>
					<span>Consultar este producto</span>
					<span aria-hidden="true">→</span>
				</a>

				<p class="product-delivery-note">
					Entrega estimada: 2 días hábiles en Lima
					Metropolitana. Envíos a provincias por
					agencia.
				</p>
			</div>
		</section>

		<section class="product-details">
			<div class="product-detail-column">
				<p class="section-eyebrow">
					Detalles de la pieza
				</p>

				<h2>Diseño, material y precisión.</h2>
			</div>

			<div class="product-description">
				{
					product.description &&
						product.description.length > 0 && (
							<PortableText
								value={product.description}
							/>
						)
				}

				{
					product.materials &&
						product.materials.length > 0 && (
							<div class="product-materials">
								<h3>Materiales</h3>

								<ul>
									{product.materials.map(
										(material) => (
											<li>{material}</li>
										),
									)}
								</ul>
							</div>
						)
				}

				{product.careInstructions && (
					<div class="product-care">
						<h3>Cuidados</h3>
						<p>{product.careInstructions}</p>
					</div>
				)}
			</div>
		</section>

		{
			product.engravingIncluded && (
				<section class="engraving-section">
					<div>
						<p class="section-eyebrow">
							Personalización incluida
						</p>

						<h2>
							Una pieza hecha para llevar tu
							historia.
						</h2>
					</div>

					<div class="engraving-information">
						<p>
							El grabado láser personalizado está
							incluido sin costo adicional.
						</p>

						{
							product.engravingTypes &&
								product.engravingTypes.length >
									0 && (
									<ul>
										{product.engravingTypes.map(
											(type) => (
												<li>
													{engravingLabels[
														type
													] || type}
												</li>
											),
										)}
									</ul>
								)
						}

						{
							product.engravingMaxCharacters && (
								<p>
									Hasta{" "}
									<strong>
										{
											product.engravingMaxCharacters
										}
									</strong>{" "}
									caracteres.
								</p>
							)
						}
					</div>
				</section>
			)
		}

		<script
			id="product-variant-data"
			type="application/json"
			set:html={safeVariantJson}
		></script>
	</main>
</BaseLayout>

<script>
	import { addItem } from "../../lib/cart";

	const initializeProductPage = () => {
		const dataElement =
			document.querySelector<HTMLScriptElement>(
				"#product-variant-data",
			);

		if (!dataElement) return;

		const parsedData = JSON.parse(
			dataElement.textContent || "{}",
		);

		const variants = parsedData.variants || [];
		const saleActive =
			parsedData.saleActive === true;
		const productMode =
			parsedData.productMode || "unique";
		const uniqueProductInfo =
			parsedData.uniqueProduct || null;
		const productInfo = parsedData.product || {};

		const woodButtons = Array.from(
			document.querySelectorAll<HTMLButtonElement>(
				"[data-option-wood]",
			),
		);

		const sizeButtons = Array.from(
			document.querySelectorAll<HTMLButtonElement>(
				"[data-option-size]",
			),
		);

		const priceElement =
			document.querySelector<HTMLElement>(
				"#product-price",
			);

		const regularPriceElement =
			document.querySelector<HTMLElement>(
				"#product-regular-price",
			);

		const skuElement =
			document.querySelector<HTMLElement>(
				"#product-sku",
			);

		const stockLabel =
			document.querySelector<HTMLElement>(
				"#product-stock-label",
			);

		const stockDot =
			document.querySelector<HTMLElement>(
				"#product-stock-dot",
			);

		const messageElement =
			document.querySelector<HTMLElement>(
				"#product-variation-message",
			);

		const contactButton =
			document.querySelector<HTMLAnchorElement>(
				"#product-contact-button",
			);

		const addToCartButton =
			document.querySelector<HTMLButtonElement>(
				"#product-add-to-cart",
			);

		const addToCartLabel =
			document.querySelector<HTMLElement>(
				"#product-add-to-cart-label",
			);

		const quantityInput =
			document.querySelector<HTMLInputElement>(
				"#product-quantity-input",
			);

		const quantityDecrease =
			document.querySelector<HTMLButtonElement>(
				"[data-quantity-decrease]",
			);

		const quantityIncrease =
			document.querySelector<HTMLButtonElement>(
				"[data-quantity-increase]",
			);

		let selectedWood =
			woodButtons.find((button) =>
				button.classList.contains("is-selected"),
			)?.dataset.value || "";

		let selectedSize =
			sizeButtons.find((button) =>
				button.classList.contains("is-selected"),
			)?.dataset.value || "";

		const formatPrice = (value: number) =>
			new Intl.NumberFormat("es-PE", {
				style: "currency",
				currency: "PEN",
				minimumFractionDigits: 2,
			}).format(value);

		const findVariant = () =>
			variants.find((variant: any) => {
				const woodMatches =
					!woodButtons.length ||
					variant.woodSlug === selectedWood;

				const sizeMatches =
					!sizeButtons.length ||
					variant.sizeSlug === selectedSize;

				return woodMatches && sizeMatches;
			});

		const getCurrentSelection = () => {
			if (productMode === "unique") {
				if (!uniqueProductInfo) return null;

				return {
					sku: uniqueProductInfo.sku || "",
					price: uniqueProductInfo.price || 0,
					salePrice:
						uniqueProductInfo.salePrice,
					stock: uniqueProductInfo.stock || 0,
					woodTitle: "",
					sizeTitle: "",
				};
			}

			const variant = findVariant();
			if (!variant) return null;

			return {
				sku: variant.sku || "",
				price: variant.price || 0,
				salePrice: variant.salePrice,
				stock: variant.stock || 0,
				woodTitle: variant.woodTitle || "",
				sizeTitle: variant.sizeTitle || "",
			};
		};

		const updateInterface = () => {
			if (!variants.length) return;

			const variant = findVariant();

			if (!variant) {
				if (messageElement) {
					messageElement.textContent =
						"Esta combinación no está disponible.";
				}

				contactButton?.classList.add(
					"is-disabled",
				);

				addToCartButton?.classList.add(
					"is-disabled",
				);

				return;
			}

			if (messageElement) {
				messageElement.textContent = "";
			}

			const hasSale =
				saleActive &&
				typeof variant.salePrice === "number";

			if (priceElement) {
				priceElement.textContent = formatPrice(
					hasSale
						? variant.salePrice
						: variant.price,
				);
			}

			if (regularPriceElement) {
				regularPriceElement.textContent =
					formatPrice(variant.price);

				regularPriceElement.classList.toggle(
					"is-hidden",
					!hasSale,
				);
			}

			if (skuElement) {
				skuElement.textContent =
					variant.sku || "Sin SKU";
			}

			const stock = Number(variant.stock || 0);

			if (stockLabel) {
				stockLabel.textContent =
					stock > 0
						? `${stock} unidades disponibles`
						: "Temporalmente agotado";
			}

			stockDot?.classList.toggle(
				"is-out",
				stock <= 0,
			);

			contactButton?.classList.toggle(
				"is-disabled",
				stock <= 0,
			);

			addToCartButton?.classList.toggle(
				"is-disabled",
				stock <= 0,
			);
		};

		const selectButton = (
			button: HTMLButtonElement,
			buttons: HTMLButtonElement[],
		) => {
			buttons.forEach((currentButton) => {
				const selected =
					currentButton === button;

				currentButton.classList.toggle(
					"is-selected",
					selected,
				);

				currentButton.setAttribute(
					"aria-pressed",
					String(selected),
				);
			});
		};

		woodButtons.forEach((button) => {
			button.addEventListener("click", () => {
				selectButton(button, woodButtons);

				selectedWood =
					button.dataset.value || "";

				updateInterface();
			});
		});

		sizeButtons.forEach((button) => {
			button.addEventListener("click", () => {
				selectButton(button, sizeButtons);

				selectedSize =
					button.dataset.value || "";

				updateInterface();
			});
		});

		const getQuantity = () => {
			const value = Number(
				quantityInput?.value || 1,
			);

			if (!Number.isFinite(value) || value < 1) {
				return 1;
			}

			return Math.floor(value);
		};

		const setQuantity = (value: number) => {
			if (!quantityInput) return;

			quantityInput.value = String(
				Math.max(1, Math.floor(value)),
			);
		};

		quantityDecrease?.addEventListener(
			"click",
			() => {
				setQuantity(getQuantity() - 1);
			},
		);

		quantityIncrease?.addEventListener(
			"click",
			() => {
				setQuantity(getQuantity() + 1);
			},
		);

		quantityInput?.addEventListener(
			"change",
			() => {
				setQuantity(getQuantity());
			},
		);

		addToCartButton?.addEventListener(
			"click",
			() => {
				if (
					addToCartButton.classList.contains(
						"is-disabled",
					)
				) {
					return;
				}

				const selection =
					getCurrentSelection();

				if (!selection) {
					if (messageElement) {
						messageElement.textContent =
							"Elige una combinación disponible antes de agregar al carrito.";
					}

					return;
				}

				const hasSale =
					saleActive &&
					typeof selection.salePrice ===
						"number";

				const unitPrice = hasSale
					? selection.salePrice
					: selection.price;

				const cartId = [
					productInfo.slug,
					selection.woodTitle,
					selection.sizeTitle,
				]
					.filter(Boolean)
					.join("__");

				addItem({
					id: cartId || productInfo.slug,
					slug: productInfo.slug,
					title: productInfo.title,
					image: productInfo.image || "",
					sku: selection.sku,
					woodTitle:
						selection.woodTitle || undefined,
					sizeTitle:
						selection.sizeTitle || undefined,
					unitPrice,
					quantity: getQuantity(),
				});

				setQuantity(1);

				if (addToCartLabel) {
					const previousLabel =
						addToCartLabel.textContent;

					addToCartLabel.textContent =
						"Agregado ✓";

					window.setTimeout(() => {
						addToCartLabel.textContent =
							previousLabel;
					}, 1600);
				}
			},
		);

		const mainImage =
			document.querySelector<HTMLImageElement>(
				"#product-main-image",
			);

		const thumbnailButtons = Array.from(
			document.querySelectorAll<HTMLButtonElement>(
				"[data-product-thumbnail]",
			),
		);

		thumbnailButtons.forEach((button) => {
			button.addEventListener("click", () => {
				if (!mainImage) return;

				mainImage.src =
					button.dataset.largeImage || "";

				mainImage.alt =
					button.dataset.imageAlt || "";

				thumbnailButtons.forEach(
					(currentButton) => {
						currentButton.classList.toggle(
							"is-active",
							currentButton === button,
						);
					},
				);
			});
		});

		updateInterface();
	};

	initializeProductPage();

	document.addEventListener(
		"astro:page-load",
		initializeProductPage,
	);
</script>

