---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import ProductCard from "../../../components/ProductCard.astro";

import {
	sanityClient,
} from "../../../lib/sanity";

import {
	productsForSubcategoryQuery,
	subcategoryPathsQuery,
} from "../../../lib/subcategoryQueries";

interface Category {
	_id?: string;
	title?: string;
	slug?: string;
	eyebrow?: string;
	description?: string;
}

interface Subcategory {
	_id?: string;
	title?: string;
	slug?: string;
	description?: string;
	order?: number;
	category?: Category;
}

interface Product {
	_id: string;
	title: string;
	slug: string;
	[key: string]: unknown;
}

export async function getStaticPaths() {
	const subcategories =
		await sanityClient.fetch<Subcategory[]>(
			subcategoryPathsQuery,
		);

	const paths = await Promise.all(
		subcategories
			.filter(
				(subcategory) =>
					subcategory.slug &&
					subcategory.category?.slug,
			)
			.map(async (subcategory) => {
				const categorySlug =
					subcategory.category!.slug!;

				const subcategorySlug =
					subcategory.slug!;

				const products =
					await sanityClient.fetch<Product[]>(
						productsForSubcategoryQuery,
						{
							categorySlug,
							subcategorySlug,
						},
					);

				return {
					params: {
						categoria: categorySlug,
						subcategoria: subcategorySlug,
					},

					props: {
						category:
							subcategory.category,
						subcategory,
						products,
					},
				};
			}),
	);

	return paths;
}

const {
	category,
	subcategory,
	products,
} = Astro.props as {
	category: Category;
	subcategory: Subcategory;
	products: Product[];
};

const base =
	import.meta.env.BASE_URL;

const categoryHref =
	`${base}categorias/${category.slug}/`;

const homeHref = base;

const pageTitle =
	`${subcategory.title} | ${category.title} | TAQTO`;

const pageDescription =
	subcategory.description ||
	`Descubre ${subcategory.title} de TAQTO, piezas de madera creadas con precisión y personalización láser gratuita.`;
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
>
	<Header />

	<main class="subcategory-page">
		<nav
			class="subcategory-breadcrumbs"
			aria-label="Migas de pan"
		>
			<a href={homeHref}>Inicio</a>
			<span aria-hidden="true">/</span>

			<a href={categoryHref}>
				{category.title}
			</a>

			<span aria-hidden="true">/</span>

			<span>{subcategory.title}</span>
		</nav>

		<header class="subcategory-hero">
			<div class="subcategory-hero__content">
				<p class="subcategory-eyebrow">
					{
						category.eyebrow ||
							category.title
					}
				</p>

				<h1>{subcategory.title}</h1>

				<p class="subcategory-description">
					{
						subcategory.description ||
							`Explora la colección ${subcategory.title} de TAQTO.`
					}
				</p>
			</div>

			<div class="subcategory-summary">
				<span>
					{products.length}
				</span>

				<p>
					{
						products.length === 1
							? "pieza disponible"
							: "piezas disponibles"
					}
				</p>
			</div>
		</header>

		<div class="subcategory-divider"></div>

		{
			products.length > 0 ? (
				<section
					class="product-grid"
					aria-label={`Productos de ${subcategory.title}`}
				>
					{
						products.map((product) => (
							<ProductCard
								product={product}
							/>
						))
					}
				</section>
			) : (
				<section class="subcategory-empty">
					<p class="subcategory-empty__eyebrow">
						Colección en preparación
					</p>

					<h2>
						Aún no hay productos publicados.
					</h2>

					<p>
						Estamos preparando nuevas piezas para
						esta categoría.
					</p>

					<a href={categoryHref}>
						Volver a {category.title}
						<span aria-hidden="true">→</span>
					</a>
				</section>
			)
		}
	</main>
</BaseLayout>

<style>
	.subcategory-page {
		min-height: 100vh;
		padding:
			clamp(175px, 15vw, 225px)
			clamp(20px, 5vw, 82px)
			clamp(80px, 9vw, 135px);
		background: #fff6ed;
		color: #141414;
	}

	.subcategory-breadcrumbs,
	.subcategory-hero,
	.subcategory-divider,
	.product-grid,
	.subcategory-empty {
		width: min(100%, 1450px);
		margin-inline: auto;
	}

	.subcategory-breadcrumbs {
		margin-bottom: 28px;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 9px;
		color: rgba(20, 20, 20, 0.5);
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.subcategory-breadcrumbs a {
		color: inherit;
		text-decoration: none;
	}

	.subcategory-breadcrumbs a:hover {
		color: #141414;
	}

	.subcategory-hero {
		display: grid;
		grid-template-columns:
			minmax(0, 1fr)
			auto;
		align-items: end;
		gap: 50px;
	}

	.subcategory-hero__content {
		max-width: 900px;
	}

	.subcategory-eyebrow {
		margin: 0 0 14px;
		color: #ff4d2a;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.subcategory-hero h1 {
		margin: 0;
		font-size: clamp(50px, 8vw, 116px);
		font-weight: 600;
		line-height: 0.88;
		letter-spacing: -0.065em;
		text-wrap: balance;
	}

	.subcategory-description {
		max-width: 680px;
		margin: 25px 0 0;
		color: rgba(20, 20, 20, 0.62);
		font-size: 15px;
		line-height: 1.65;
	}

	.subcategory-summary {
		min-width: 145px;
		padding: 21px;
		border: 1px solid
			rgba(20, 20, 20, 0.1);
		border-radius: 18px;
		text-align: center;
	}

	.subcategory-summary span {
		display: block;
		font-size: 34px;
		font-weight: 600;
		letter-spacing: -0.04em;
	}

	.subcategory-summary p {
		margin: 5px 0 0;
		color: rgba(20, 20, 20, 0.5);
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.subcategory-divider {
		height: 1px;
		margin-top: clamp(45px, 6vw, 75px);
		margin-bottom: clamp(40px, 5vw, 65px);
		background: rgba(20, 20, 20, 0.11);
	}

	.product-grid {
	display: grid;
	grid-template-columns:
		repeat(
			auto-fill,
			minmax(min(100%, 250px), 300px)
		);
	justify-content: start;
	gap: 36px 24px;
}

	.subcategory-empty {
		padding: clamp(50px, 7vw, 90px) 25px;
		border: 1px solid
			rgba(20, 20, 20, 0.1);
		border-radius: 24px;
		text-align: center;
	}

	.subcategory-empty__eyebrow {
		margin: 0 0 12px;
		color: #ff4d2a;
		font-size: 9px;
		font-weight: 700;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.subcategory-empty h2 {
		margin: 0;
		font-size: clamp(32px, 5vw, 56px);
		line-height: 1;
		letter-spacing: -0.045em;
	}

	.subcategory-empty > p:not(
			.subcategory-empty__eyebrow
		) {
		margin: 16px 0 0;
		color: rgba(20, 20, 20, 0.6);
	}

	.subcategory-empty a {
		margin-top: 25px;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: #141414;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}

	@media (max-width: 950px) {
	.product-grid {
		grid-template-columns:
			repeat(
				auto-fill,
				minmax(min(100%, 240px), 1fr)
			);
	}
}

	@media (max-width: 700px) {
		.subcategory-page {
			padding:
				150px 14px
				75px;
		}

		.subcategory-hero {
			grid-template-columns: 1fr;
			align-items: start;
			gap: 28px;
		}

		.subcategory-summary {
			min-width: 0;
			width: 100%;
			display: flex;
			align-items: center;
			justify-content: space-between;
			text-align: left;
		}

		.subcategory-summary p {
			margin: 0;
		}
	}

	@media (max-width: 560px) {
		.product-grid {
			grid-template-columns: 1fr;
			gap: 50px;
		}
	}
</style>