---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import ProductCard from "../../../components/ProductCard.astro";
import CategoryHeroBanner from "../../../components/CategoryHeroBanner.astro";

import {
	sanityClient,
} from "../../../lib/sanity";

import {
	categoryPageQuery,
	categoryPathsQuery,
} from "../../../lib/categoryQueries";

interface Subcategory {
	_id: string;
	title: string;
	slug: string;
	description?: string;
	order?: number;
	productCount?: number;
}

interface Product {
	_id: string;
	title: string;
	slug: string;
	[key: string]: unknown;
}

interface Category {
	_id: string;
	title: string;
	slug: string;
	eyebrow?: string;
	description?: string;
	order?: number;
	subcategories?: Subcategory[];
	products?: Product[];
}

export async function getStaticPaths() {
	const categories =
		await sanityClient.fetch<Category[]>(
			categoryPathsQuery,
		);

	return categories
		.filter((category) => category.slug)
		.map((category) => ({
			params: {
				categoria: category.slug,
			},

			props: {
				categorySlug: category.slug,
			},
		}));
}

const {
	categorySlug,
} = Astro.props as {
	categorySlug: string;
};

const category =
	await sanityClient.fetch<Category>(
		categoryPageQuery,
		{
			categorySlug,
		},
	);

if (!category) {
	return Astro.redirect(
		`${import.meta.env.BASE_URL}categorias/`,
	);
}

const base = import.meta.env.BASE_URL;

const homeHref = base;
const storeHref = `${base}categorias/`;

const subcategories =
	category.subcategories || [];

const products =
	category.products || [];

const pageTitle =
	`${category.title} | TAQTO`;

const pageDescription =
	category.description ||
	`Explora la colección ${category.title} de TAQTO.`;
---

<BaseLayout
	title={pageTitle}
	description={pageDescription}
>
	<Header />

	<main class="category-page">
		<nav
			class="category-breadcrumbs"
			aria-label="Migas de pan"
		>
			<a href={homeHref}>Inicio</a>

			<span aria-hidden="true">/</span>

			<a href={storeHref}>Tienda</a>

			<span aria-hidden="true">/</span>

			<span>{category.title}</span>
		</nav>

		<CategoryHeroBanner
			categorySlug={category.slug}
			eyebrow={category.eyebrow || "Colección TAQTO"}
			title={category.title}
			description={category.description}
			count={products.length}
			countLabel={
				products.length === 1 ? "pieza" : "piezas"
			}
		/>

		{
			subcategories.length > 0 && (
				<section class="subcategory-navigation">
					<p class="section-label">
						Explorar colección
					</p>

					<div class="subcategory-navigation__grid">
						{
							subcategories.map(
								(subcategory) => (
									<a
										class="subcategory-link"
										href={`${base}categorias/${category.slug}/${subcategory.slug}/`}
									>
										{subcategory.title}

										<span class="subcategory-link__count">
											{subcategory.productCount || 0}
										</span>
									</a>
								),
							)
						}
					</div>
				</section>
			)
		}

		<section class="category-products">
			<div class="category-products__header">
				<div>
					<p class="section-label">
						Catálogo
					</p>

					<h2>
						Piezas de {category.title}
					</h2>
				</div>

				<p>
					Grabado láser personalizado siempre
					gratuito.
				</p>
			</div>

			{
				products.length > 0 ? (
					<div class="product-grid">
						{
							products.map((product) => (
								<ProductCard
									product={product}
								/>
							))
						}
					</div>
				) : (
					<div class="category-empty">
						<h3>
							Colección en preparación
						</h3>

						<p>
							Aún no hay productos publicados
							dentro de esta categoría.
						</p>
					</div>
				)
			}
		</section>
	</main>
</BaseLayout>

<style>
	.category-page {
		min-height: 100vh;
		padding:
			clamp(24px, 3vw, 40px)
			clamp(20px, 5vw, 82px)
			clamp(80px, 9vw, 140px);
		background: #fff6ed;
		color: #141414;
	}

	.category-breadcrumbs,
	.subcategory-navigation,
	.category-products {
		width: min(100%, 1450px);
		margin-inline: auto;
	}

	.category-breadcrumbs {
		margin-bottom: 28px;
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 9px;
		color: rgba(20, 20, 20, 0.5);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.category-breadcrumbs a {
		color: inherit;
		text-decoration: none;
	}

	.section-label {
		margin: 0 0 14px;
		color: #ff4d2a;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.subcategory-navigation {
		margin-top: clamp(20px, 2.5vw, 28px);
		padding-top: 18px;
		border-top: 1px solid rgba(20, 20, 20, 0.1);
	}

	.subcategory-navigation__grid {
		display: flex;
		flex-wrap: wrap;
		gap: 9px;
	}

	.subcategory-link {
		min-height: 42px;
		padding: 0 16px;
		display: inline-flex;
		align-items: center;
		gap: 9px;
		border: 1px solid rgba(20, 20, 20, 0.14);
		border-radius: 999px;
		color: #141414;
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	.subcategory-link:hover {
		background: #141414;
		border-color: #141414;
		color: #fff6ed;
	}

	.subcategory-link__count {
		min-width: 20px;
		height: 20px;
		padding-inline: 5px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: rgba(20, 20, 20, 0.08);
		font-size: 11px;
		font-weight: 700;
	}

	.subcategory-link:hover .subcategory-link__count {
		background: rgba(255, 255, 255, 0.16);
	}

	.category-products {
		margin-top: clamp(32px, 4vw, 52px);
	}

	.category-products__header {
		margin-bottom: 26px;
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 40px;
	}

	.category-products__header h2 {
		margin: 0;
		font-size: clamp(36px, 5vw, 66px);
		font-weight: 600;
		line-height: 0.96;
		letter-spacing: -0.05em;
	}

	.category-products__header > p {
		max-width: 260px;
		margin: 0;
		color: rgba(20, 20, 20, 0.52);
		font-size: 11px;
		line-height: 1.55;
		text-align: right;
	}

	.product-grid {
		display: grid;
		grid-template-columns:
			repeat(
				auto-fill,
				minmax(min(100%, 250px), 300px)
			);
		justify-content: start;
		gap: 36px 24px;
	}

	.category-empty {
		padding: 70px 25px;
		border: 1px solid rgba(20, 20, 20, 0.1);
		border-radius: 22px;
		text-align: center;
	}

	.category-empty h3 {
		margin: 0;
		font-size: 34px;
	}

	.category-empty p {
		margin: 12px 0 0;
		color: rgba(20, 20, 20, 0.58);
	}

	@media (max-width: 760px) {
		.category-page {
			padding:
				20px 14px
				75px;
		}

		.category-products__header {
			align-items: flex-start;
			flex-direction: column;
			gap: 16px;
		}

		.category-products__header > p {
			text-align: left;
		}
	}

	@media (max-width: 560px) {
		.product-grid {
			grid-template-columns: 1fr;
			gap: 50px;
		}
	}
</style>