---
const base = import.meta.env.BASE_URL;
const historyHref = `${base}nosotros/`;

const features = [
	{
		number: "01",
		title: "Tradición",
		description:
			"Conocimiento transmitido a través del oficio, la experiencia y el respeto por la materia.",
	},
	{
		number: "02",
		title: "Ingeniería",
		description:
			"Proporción, funcionalidad y precisión aplicadas al diseño de cada pieza.",
	},
	{
		number: "03",
		title: "Tecnología",
		description:
			"Herramientas contemporáneas que elevan el oficio sin perder su origen artesanal.",
	},
];
---

<section class="origin">
	<div class="origin__card">
		<div class="origin__text">
			<p class="origin__eyebrow">
				El origen de TAQTO
			</p>

			<h2>
				Diseño que nace con tradición
			</h2>

			<p class="origin__description">
				TAQTO nace del oficio de trabajar la madera
				con paciencia y precisión. Hoy combinamos ese
				conocimiento artesanal con ingeniería y
				tecnología para crear piezas hechas para
				acompañar tu día a día.
			</p>

			<a class="origin__cta" href={historyHref}>
				<span>Conoce nuestra historia</span>
				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="M5 12h14" />
					<path d="m14 7 5 5-5 5" />
				</svg>
			</a>

			<div class="origin__divider"></div>

			<p class="origin__tagline">
				El legado continúa en cada pieza.
			</p>
		</div>

		<aside class="origin__stat" data-origin-stat>
			<p class="origin__stat-label">Más de</p>

			<p class="origin__stat-number">
				<span
					data-counter-target="20"
					data-counter-current="0"
				>
					0
				</span>
			</p>

			<p class="origin__stat-caption">
				años de tradición
			</p>

			<div class="origin__stat-divider"></div>

			<ul class="origin__stat-list">
				{features.map((feature) => (
					<li>
						<span class="origin__stat-index">
							{feature.number}
						</span>

						<div>
							<strong>{feature.title}</strong>
							<p>{feature.description}</p>
						</div>
					</li>
				))}
			</ul>
		</aside>
	</div>
</section>

<script>
	const initOriginCounters = () => {
		const counters =
			document.querySelectorAll<HTMLElement>(
				"[data-counter-target]",
			);

		if (!counters.length) return;

		const animateCounter = (el: HTMLElement) => {
			if (el.dataset.counterDone === "true") return;
			el.dataset.counterDone = "true";

			const target = Number(
				el.dataset.counterTarget || "0",
			);

			const duration = 1400;
			const start = performance.now();

			const step = (now: number) => {
				const progress = Math.min(
					(now - start) / duration,
					1,
				);

				const eased =
					1 - Math.pow(1 - progress, 3);

				el.textContent = String(
					Math.round(target * eased),
				);

				if (progress < 1) {
					requestAnimationFrame(step);
				}
			};

			requestAnimationFrame(step);
		};

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						animateCounter(
							entry.target as HTMLElement,
						);
					}
				});
			},
			{ threshold: 0.5 },
		);

		counters.forEach((counter) =>
			observer.observe(counter),
		);
	};

	initOriginCounters();

	document.addEventListener(
		"astro:page-load",
		initOriginCounters,
	);
</script>

<style>
	.origin {
		padding:
			clamp(20px, 3vw, 40px)
			var(--page-padding)
			clamp(50px, 7vw, 90px);
		background: var(--color-beige);
	}

	.origin__card {
		position: relative;
		width: min(100%, var(--page-width));
		margin-inline: auto;
		padding: clamp(30px, 4vw, 50px);
		overflow: hidden;
		border-radius: 28px;
		background:
			radial-gradient(
				circle at 15% 20%,
				rgba(255, 77, 42, 0.16),
				transparent 55%
			),
			var(--color-black);
		color: var(--color-beige);
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.85fr);
		gap: clamp(30px, 5vw, 70px);
		align-items: center;
	}

	.origin__eyebrow {
		margin: 0 0 14px;
		color: var(--color-orange);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.origin__text h2 {
		margin: 0;
		font-size: clamp(28px, 3.6vw, 42px);
		font-weight: 600;
		line-height: 1.08;
		letter-spacing: -0.02em;
	}

	.origin__description {
		max-width: 460px;
		margin: 18px 0 0;
		color: rgba(255, 246, 237, 0.72);
		font-size: 14.5px;
		line-height: 1.65;
	}

	.origin__cta {
		margin-top: 24px;
		min-height: 50px;
		padding-inline: 22px;
		display: inline-flex;
		align-items: center;
		gap: 12px;
		border-radius: 13px;
		background: var(--color-brown);
		color: var(--color-beige);
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			transform 180ms ease;
	}

	.origin__cta svg {
		width: 16px;
		height: 16px;
	}

	.origin__cta:hover {
		background: var(--color-orange);
		transform: translateY(-2px);
	}

	.origin__divider {
		margin-top: 30px;
		height: 1px;
		background: rgba(255, 255, 255, 0.14);
	}

	.origin__tagline {
		margin: 18px 0 0;
		color: rgba(255, 246, 237, 0.45);
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.origin__stat {
		padding: clamp(24px, 3vw, 32px);
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 22px;
		background: rgba(255, 255, 255, 0.05);
		backdrop-filter: blur(10px);
	}

	.origin__stat-label {
		margin: 0;
		color: rgba(255, 246, 237, 0.5);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.origin__stat-number {
		margin: 6px 0 0;
		font-size: clamp(54px, 7vw, 84px);
		font-weight: 700;
		line-height: 1;
		letter-spacing: -0.03em;
		color: var(--color-orange);
	}

	.origin__stat-caption {
		margin: 4px 0 0;
		font-size: 13px;
		font-weight: 600;
		color: rgba(255, 246, 237, 0.75);
	}

	.origin__stat-divider {
		margin: 22px 0;
		height: 1px;
		background: rgba(255, 255, 255, 0.14);
	}

	.origin__stat-list {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.origin__stat-list li {
		display: flex;
		gap: 14px;
	}

	.origin__stat-index {
		flex-shrink: 0;
		color: var(--color-orange);
		font-size: 12px;
		font-weight: 700;
	}

	.origin__stat-list strong {
		display: block;
		margin-bottom: 4px;
		font-size: 14px;
		font-weight: 700;
	}

	.origin__stat-list p {
		margin: 0;
		color: rgba(255, 246, 237, 0.6);
		font-size: 12.5px;
		line-height: 1.5;
	}

	@media (max-width: 900px) {
		.origin__card {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 600px) {
		.origin__card {
			border-radius: 22px;
			padding: 26px 20px;
		}
	}
</style>
