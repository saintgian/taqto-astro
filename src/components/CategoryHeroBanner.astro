---
interface Props {
	categorySlug: string;
	eyebrow?: string;
	title: string;
	description?: string;
	count: number;
	countLabel: string;
}

const {
	categorySlug,
	eyebrow,
	title,
	description,
	count,
	countLabel,
} = Astro.props;

const embers = Array.from({ length: 12 });
const steams = Array.from({ length: 5 });
---

<header class:list={["theme-hero", `theme-hero--${categorySlug}`]}>
	<div class="theme-hero__effect" aria-hidden="true">
		{
			categorySlug === "parrilla" &&
				embers.map((_, i) => (
					<span class="ember" style={`--i:${i}`} />
				))
		}

		{
			categorySlug === "cocina-y-mesa" &&
				steams.map((_, i) => (
					<span class="steam" style={`--i:${i}`} />
				))
		}

		{
			categorySlug === "oficina" && (
				<>
					<span class="office-grid" />
					<span class="scan-line" />
				</>
			)
		}
	</div>

	<div class="theme-hero__content">
		{
			eyebrow && (
				<p class="theme-hero__eyebrow">{eyebrow}</p>
			)
		}

		<h1>{title}</h1>

		{
			description && (
				<p class="theme-hero__description">
					{description}
				</p>
			)
		}

		<div class="theme-hero__count">
			<strong>{count}</strong>
			<span>{countLabel}</span>
		</div>
	</div>
</header>

<style>
	.theme-hero {
		position: relative;
		width: min(100%, 1450px);
		margin-inline: auto;
		overflow: hidden;
		padding: clamp(26px, 3.5vw, 42px) clamp(20px, 5vw, 60px);
		border-radius: 26px;
		background:
			radial-gradient(
				circle at 50% 0%,
				rgba(255, 255, 255, 0.05),
				transparent 60%
			),
			#141414;
		color: #fff6ed;
		text-align: center;
	}

	.theme-hero__effect {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
	}

	.theme-hero__content {
		position: relative;
		z-index: 1;
		max-width: 760px;
		margin-inline: auto;
	}

	.theme-hero__eyebrow {
		margin: 0 0 14px;
		color: #ff8a5c;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.theme-hero h1 {
		margin: 0;
		font-size: clamp(32px, 5vw, 56px);
		font-weight: 600;
		line-height: 1;
		letter-spacing: -0.03em;
	}

	.theme-hero__description {
		max-width: 560px;
		margin: 12px auto 0;
		color: rgba(255, 246, 237, 0.72);
		font-size: 15px;
		line-height: 1.55;
	}

	.theme-hero__count {
		margin: 18px auto 0;
		width: fit-content;
		padding: 10px 22px;
		display: inline-flex;
		align-items: baseline;
		gap: 8px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.06);
	}

	.theme-hero__count strong {
		font-size: 20px;
		font-weight: 700;
	}

	.theme-hero__count span {
		color: rgba(255, 246, 237, 0.6);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	/* ---------- PARRILLA: brasas ---------- */

	.theme-hero--parrilla {
		background:
			radial-gradient(
				circle at 50% 110%,
				rgba(255, 106, 42, 0.35),
				transparent 60%
			),
			#161311;
	}

	.ember {
		position: absolute;
		bottom: -10px;
		left: calc(var(--i) * 8.5% + 2%);
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: #ff8a3d;
		box-shadow: 0 0 8px 2px rgba(255, 138, 61, 0.8);
		opacity: 0;
		animation: ember-rise 4.5s ease-in infinite;
		animation-delay: calc(var(--i) * 0.4s);
	}

	.ember:nth-child(3n) {
		background: #ff4d2a;
		width: 4px;
		height: 4px;
	}

	.ember:nth-child(4n) {
		background: #ffc36b;
		width: 3px;
		height: 3px;
	}

	@keyframes ember-rise {
		0% {
			transform: translateY(0) translateX(0);
			opacity: 0;
		}
		12% {
			opacity: 1;
		}
		100% {
			transform: translateY(-160px) translateX(14px);
			opacity: 0;
		}
	}

	/* ---------- COCINA Y MESA: vapor calido ---------- */

	.theme-hero--cocina-y-mesa {
		background:
			radial-gradient(
				circle at 50% 100%,
				rgba(255, 200, 150, 0.22),
				transparent 65%
			),
			#181410;
	}

	.steam {
		position: absolute;
		bottom: -30px;
		left: calc(var(--i) * 19% + 8%);
		width: 60px;
		height: 100px;
		border-radius: 50%;
		background: rgba(255, 246, 237, 0.12);
		filter: blur(10px);
		opacity: 0;
		animation: steam-rise 7s ease-in-out infinite;
		animation-delay: calc(var(--i) * 1.1s);
	}

	@keyframes steam-rise {
		0% {
			transform: translateY(0) scale(0.8);
			opacity: 0;
		}
		30% {
			opacity: 0.9;
		}
		100% {
			transform: translateY(-180px) scale(1.3);
			opacity: 0;
		}
	}

	/* ---------- OFICINA: precision ---------- */

	.theme-hero--oficina {
		background: #131417;
	}

	.office-grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(
				rgba(255, 255, 255, 0.05) 1px,
				transparent 1px
			),
			linear-gradient(
				90deg,
				rgba(255, 255, 255, 0.05) 1px,
				transparent 1px
			);
		background-size: 42px 42px;
		mask-image: radial-gradient(
			circle at 50% 40%,
			#000 40%,
			transparent 78%
		);
	}

	.scan-line {
		position: absolute;
		top: 0;
		left: -20%;
		width: 30%;
		height: 100%;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 138, 92, 0.16),
			transparent
		);
		animation: scan-sweep 6s ease-in-out infinite;
	}

	@keyframes scan-sweep {
		0% {
			left: -30%;
		}
		50% {
			left: 100%;
		}
		100% {
			left: -30%;
		}
	}

	/* ---------- Default (kits y regalos, empresas, etc.) ---------- */

	.theme-hero:not(.theme-hero--parrilla):not(.theme-hero--cocina-y-mesa):not(.theme-hero--oficina) {
		background:
			radial-gradient(
				circle at 50% 0%,
				rgba(255, 77, 42, 0.16),
				transparent 65%
			),
			#141414;
	}

	@media (prefers-reduced-motion: reduce) {
		.ember,
		.steam,
		.scan-line {
			animation: none;
			opacity: 0;
		}
	}

	@media (max-width: 640px) {
		.theme-hero {
			padding: 32px 18px;
			border-radius: 20px;
		}
	}
</style>
