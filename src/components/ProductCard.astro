---
import {
	formatPEN,
	getProductPriceRange,
	isSaleActive,
} from "../lib/productPricing";

import {
	urlForImage,
} from "../lib/sanity";

interface Props {
	product: any;
}

const {
	product,
} = Astro.props;

const base =
	import.meta.env.BASE_URL;

const productHref =
	`${base}productos/${product.slug}/`;

const mainImage =
	product.gallery?.[0];

const imageUrl = mainImage
	? urlForImage(mainImage)
			.width(900)
			.height(1125)
			.fit("crop")
			.auto("format")
			.url()
	: "";

const imageAlt =
	mainImage?.alt ||
	product.title ||
	"Producto TAQTO";

const priceRange =
	getProductPriceRange(product);

const saleActive =
	isSaleActive(
		product.saleStart,
		product.saleEnd,
	);

const hasAnySale =
	saleActive &&
	(
		typeof product.uniqueProduct?.salePrice ===
			"number" ||
		product.variants?.some(
			(variant: any) =>
				variant.active !== false &&
				typeof variant.salePrice ===
					"number",
		)
	);

const modeLabels: Record<string, string> = {
	unique: "Pieza única",
	wood: "Elige la madera",
	size: "Elige el tamaño",
	woodSize: "Madera y tamaño",
};
---

<article class="product-card">
	<a
		class="product-card__media"
		href={productHref}
		aria-label={`Ver ${product.title}`}
	>
		{
			imageUrl ? (
				<img
					src={imageUrl}
					alt={imageAlt}
					width="900"
					height="1125"
					loading="lazy"
					decoding="async"
				/>
			) : (
				<div class="product-card__placeholder">
					<span>TAQTO</span>
					<small>Imagen pendiente</small>
				</div>
			)
		}

		<div class="product-card__badges">
			{
				hasAnySale && (
					<span class="product-card__badge product-card__badge--sale">
						Oferta
					</span>
				)
			}

			{
				product.productMode &&
					product.productMode !==
						"unique" && (
						<span class="product-card__badge">
							{
								modeLabels[
									product.productMode
								] || "Varias opciones"
							}
						</span>
					)
			}
		</div>

		<span
			class="product-card__arrow"
			aria-hidden="true"
		>
			→
		</span>
	</a>

	<div class="product-card__content">
		<p class="product-card__category">
			{
				product.subcategory?.title ||
				product.category?.title ||
				"TAQTO"
			}
		</p>

		<h2>
			<a href={productHref}>
				{product.title}
			</a>
		</h2>

		{
			product.shortDescription && (
				<p class="product-card__description">
					{product.shortDescription}
				</p>
			)
		}

		<div class="product-card__bottom">
			<p class="product-card__price">
				{
					priceRange.minimum > 0
						? priceRange.hasRange
							? `Desde ${formatPEN(
									priceRange.minimum,
								)}`
							: formatPEN(
									priceRange.minimum,
								)
						: "Precio por consultar"
				}
			</p>

			<a
				class="product-card__link"
				href={productHref}
			>
				Ver producto
				<span aria-hidden="true">→</span>
			</a>
		</div>
	</div>
</article>

<style>
	.product-card {
		min-width: 0;
	}

	.product-card__media {
	position: relative;
	display: block;
	aspect-ratio: 4 / 5;
	overflow: hidden;
	border: 1px solid rgba(20, 20, 20, 0.06);
	border-radius: 20px;
	background: #ffffff;
	color: inherit;
	text-decoration: none;
}

	.product-card__media img {
	display: block;
	width: 100%;
	height: 100%;
	object-fit: contain;
	object-position: center;
	padding: 18px;
	background: #ffffff;
		transition:
			transform 450ms
			cubic-bezier(0.22, 1, 0.36, 1);
	}

	.product-card:hover
	.product-card__media img {
	transform: scale(1.018);
}

	.product-card__placeholder {
		width: 100%;
		height: 100%;
		display: grid;
		place-content: center;
		gap: 7px;
		color: #5b312a;
		text-align: center;
	}

	.product-card__placeholder span {
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.16em;
	}

	.product-card__placeholder small {
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		opacity: 0.6;
	}

	.product-card__badges {
		position: absolute;
		top: 14px;
		left: 14px;
		display: flex;
		align-items: flex-start;
		flex-direction: column;
		gap: 7px;
	}

	.product-card__badge {
		padding: 8px 11px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 999px;
		background: rgba(20, 20, 20, 0.88);
		color: #fff6ed;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.09em;
		text-transform: uppercase;
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
	}

	.product-card__badge--sale {
		background: #ff4d2a;
	}

	.product-card__arrow {
	position: absolute;
	right: 14px;
	bottom: 14px;
	width: 42px;
	height: 42px;
	display: grid;
	place-items: center;
	border: 1px solid rgba(255, 255, 255, 0.3);
	border-radius: 50%;
	background: rgba(20, 20, 20, 0.88);
	color: #fff6ed;
	font-size: 17px;
	transform: translateY(6px);
	opacity: 0;
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	transition:
		transform 200ms ease,
		opacity 200ms ease,
		background-color 200ms ease;
}

	.product-card:hover .product-card__arrow {
	transform: translateY(0);
	background: #5b312a;
	opacity: 1;
}

	.product-card__content {
		padding: 18px 3px 0;
	}

	.product-card__category {
		margin: 0 0 8px;
		color: #ff4d2a;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.product-card h2 {
		margin: 0;
		font-size: clamp(22px, 2vw, 29px);
		font-weight: 600;
		line-height: 1.05;
		letter-spacing: -0.035em;
	}

	.product-card h2 a {
		color: #141414;
		text-decoration: none;
	}

	.product-card__description {
		display: -webkit-box;
		overflow: hidden;
		margin: 11px 0 0;
		color: rgba(20, 20, 20, 0.62);
		font-size: 13px;
		line-height: 1.55;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.product-card__bottom {
		margin-top: 18px;
		padding-top: 16px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		border-top: 1px solid
			rgba(20, 20, 20, 0.1);
	}

	.product-card__price {
		margin: 0;
		color: #141414;
		font-size: 15px;
		font-weight: 700;
	}

	.product-card__link {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		color: #141414;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.product-card__link span {
		transition: transform 180ms ease;
	}

	.product-card__link:hover span {
		transform: translateX(4px);
	}

	@media (max-width: 600px) {
		.product-card__arrow {
			transform: none;
			opacity: 1;
		}

		.product-card__description {
			font-size: 12.5px;
		}
	}
</style>