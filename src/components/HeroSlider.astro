---
const slides = [
	{
		eyebrow: "Parrilla peruana premium",
		title: "Tablas parrilleras personalizadas",
		description:
			"Piezas robustas de madera seleccionada, creadas para acompañar cada corte y cada encuentro.",
		button: "Descubre tu tabla",
		href: "/parrilla/",
		image: "/images/hero/hero-parrilla.webp",
		alt: "Tabla parrillera personalizada de madera TAQTO",
		position: "center right",
		theme: "dark",
	},
	{
		eyebrow: "Cocina y Mesa",
		title: "Diseño que transforma la mesa",
		description:
			"Objetos cálidos y contemporáneos para servir, compartir y hacer especial cada momento.",
		button: "Explorar la colección",
		href: "/cocina-y-mesa/",
		image: "/images/hero/hero-cocina.webp",
		alt: "Accesorios de madera para cocina y mesa TAQTO",
		position: "center center",
		theme: "light",
	},
	{
		eyebrow: "Orden con carácter",
		title: "Tu espacio de trabajo, mejor diseñado",
		description:
			"Organizadores y accesorios de madera pensados para trabajar con claridad, orden y estilo.",
		button: "Ver colección de oficina",
		href: "/oficina/",
		image: "/images/hero/hero-oficina.webp",
		alt: "Organizador de escritorio de madera TAQTO",
		position: "center right",
		theme: "dark",
	},
];
---

<section
	class="hero-slider"
	data-hero-slider
	aria-roledescription="carrusel"
	aria-label="Colecciones destacadas de TAQTO"
>
	<div class="hero-slider__viewport">
		{
			slides.map((slide, index) => (
				<article
					class:list={[
						"hero-slide",
						`hero-slide--${slide.theme}`,
						{ "is-active": index === 0 },
					]}
					data-slide
					aria-hidden={index === 0 ? "false" : "true"}
					style={`--slide-image: url('${slide.image}'); --slide-position: ${slide.position};`}
				>
					<img
						class="hero-slide__image"
						src={slide.image}
						alt={slide.alt}
						width="2048"
						height="900"
						loading={index === 0 ? "eager" : "lazy"}
						fetchpriority={index === 0 ? "high" : "auto"}
					/>

					<div class="hero-slide__overlay"></div>

					<div class="hero-slide__container">
						<div class="hero-slide__content">
							<p class="hero-slide__eyebrow">{slide.eyebrow}</p>

							{
								index === 0 ? (
									<h1>{slide.title}</h1>
								) : (
									<h2>{slide.title}</h2>
								)
							}

							<p class="hero-slide__description">
								{slide.description}
							</p>

							<a class="hero-slide__button" href={slide.href}>
								<span>{slide.button}</span>

								<svg
									viewBox="0 0 24 24"
									aria-hidden="true"
									fill="none"
									stroke="currentColor"
									stroke-width="1.8"
								>
									<path d="M5 12h14"></path>
									<path d="m14 7 5 5-5 5"></path>
								</svg>
							</a>

							<div class="hero-slide__trust" aria-label="Beneficios">
								<span>Grabado láser gratuito</span>
								<span>Madera seleccionada</span>
								<span>Hecho en Perú</span>
							</div>
						</div>
					</div>
				</article>
			))
		}

		<button
			class="hero-slider__arrow hero-slider__arrow--previous"
			type="button"
			data-slider-previous
			aria-label="Ver diapositiva anterior"
		>
			<svg
				viewBox="0 0 24 24"
				aria-hidden="true"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
			>
				<path d="m15 18-6-6 6-6"></path>
			</svg>
		</button>

		<button
			class="hero-slider__arrow hero-slider__arrow--next"
			type="button"
			data-slider-next
			aria-label="Ver siguiente diapositiva"
		>
			<svg
				viewBox="0 0 24 24"
				aria-hidden="true"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
			>
				<path d="m9 18 6-6-6-6"></path>
			</svg>
		</button>

		<div class="hero-slider__pagination" aria-label="Seleccionar diapositiva">
			{
				slides.map((slide, index) => (
					<button
						class:list={[
							"hero-slider__dot",
							{ "is-active": index === 0 },
						]}
						type="button"
						data-slider-dot
						aria-label={`Ver diapositiva ${index + 1}: ${slide.title}`}
						aria-current={index === 0 ? "true" : "false"}
					>
						<span></span>
					</button>
				))
			}
		</div>

		<div class="hero-slider__counter" aria-hidden="true">
			<span data-current-slide>01</span>
			<span class="hero-slider__counter-line"></span>
			<span>{String(slides.length).padStart(2, "0")}</span>
		</div>

		<div
			class="hero-slider__progress"
			aria-hidden="true"
			data-slider-progress
		></div>
	</div>
</section>

<script>
	const sliders = document.querySelectorAll<HTMLElement>("[data-hero-slider]");

	sliders.forEach((slider) => {
		const slides = Array.from(
			slider.querySelectorAll<HTMLElement>("[data-slide]"),
		);

		const dots = Array.from(
			slider.querySelectorAll<HTMLButtonElement>("[data-slider-dot]"),
		);

		const previousButton =
			slider.querySelector<HTMLButtonElement>("[data-slider-previous]");

		const nextButton =
			slider.querySelector<HTMLButtonElement>("[data-slider-next]");

		const currentCounter =
			slider.querySelector<HTMLElement>("[data-current-slide]");

		const progress =
			slider.querySelector<HTMLElement>("[data-slider-progress]");

		const autoplayDelay = 6000;
		const reducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;

		let activeIndex = 0;
		let autoplayTimer: number | undefined;

		const restartProgress = () => {
			if (!progress || reducedMotion) return;

			progress.classList.remove("is-running");
			void progress.offsetWidth;
			progress.classList.add("is-running");
		};

		const showSlide = (newIndex: number) => {
			activeIndex = (newIndex + slides.length) % slides.length;

			slides.forEach((slide, index) => {
				const isActive = index === activeIndex;

				slide.classList.toggle("is-active", isActive);
				slide.setAttribute("aria-hidden", String(!isActive));
			});

			dots.forEach((dot, index) => {
				const isActive = index === activeIndex;

				dot.classList.toggle("is-active", isActive);
				dot.setAttribute("aria-current", String(isActive));
			});

			if (currentCounter) {
				currentCounter.textContent = String(activeIndex + 1).padStart(
					2,
					"0",
				);
			}

			restartProgress();
		};

		const stopAutoplay = () => {
			if (autoplayTimer !== undefined) {
				window.clearInterval(autoplayTimer);
			}
		};

		const startAutoplay = () => {
			if (reducedMotion || slides.length <= 1) return;

			stopAutoplay();

			autoplayTimer = window.setInterval(() => {
				showSlide(activeIndex + 1);
			}, autoplayDelay);
		};

		const restartAutoplay = () => {
			stopAutoplay();
			startAutoplay();
		};

		previousButton?.addEventListener("click", () => {
			showSlide(activeIndex - 1);
			restartAutoplay();
		});

		nextButton?.addEventListener("click", () => {
			showSlide(activeIndex + 1);
			restartAutoplay();
		});

		dots.forEach((dot, index) => {
			dot.addEventListener("click", () => {
				showSlide(index);
				restartAutoplay();
			});
		});

		slider.addEventListener("mouseenter", stopAutoplay);
		slider.addEventListener("mouseleave", startAutoplay);

		slider.addEventListener("focusin", stopAutoplay);

		slider.addEventListener("focusout", (event) => {
			const nextFocus = event.relatedTarget;

			if (!(nextFocus instanceof Node) || !slider.contains(nextFocus)) {
				startAutoplay();
			}
		});

		slider.addEventListener("keydown", (event) => {
			if (event.key === "ArrowLeft") {
				showSlide(activeIndex - 1);
				restartAutoplay();
			}

			if (event.key === "ArrowRight") {
				showSlide(activeIndex + 1);
				restartAutoplay();
			}
		});

		document.addEventListener("visibilitychange", () => {
			if (document.hidden) {
				stopAutoplay();
			} else {
				startAutoplay();
			}
		});

		showSlide(0);
		startAutoplay();
	});
</script>

<style>
	.hero-slider {
		position: relative;
		width: 100%;
		background: #141414;
		overflow: hidden;
	}

	.hero-slider__viewport {
		position: relative;
		height: clamp(620px, calc(100svh - 122px), 880px);
		min-height: 620px;
		overflow: hidden;
	}

	.hero-slide {
		position: absolute;
		inset: 0;
		z-index: 0;
		display: grid;
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 900ms cubic-bezier(0.22, 1, 0.36, 1),
			visibility 900ms;
	}

	.hero-slide.is-active {
		z-index: 1;
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.hero-slide__image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		object-fit: cover;
		object-position: var(--slide-position);
		transform: scale(1.035);
		transition: transform 7s linear;
	}

	.hero-slide.is-active .hero-slide__image {
		transform: scale(1);
	}

	.hero-slide__overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
		background:
			linear-gradient(
				90deg,
				rgba(10, 8, 7, 0.88) 0%,
				rgba(10, 8, 7, 0.7) 32%,
				rgba(10, 8, 7, 0.25) 58%,
				rgba(10, 8, 7, 0.04) 100%
			),
			linear-gradient(
				0deg,
				rgba(10, 8, 7, 0.48) 0%,
				transparent 38%
			);
	}

	.hero-slide--light .hero-slide__overlay {
		background:
			linear-gradient(
				90deg,
				rgba(255, 246, 237, 0.97) 0%,
				rgba(255, 246, 237, 0.86) 35%,
				rgba(255, 246, 237, 0.3) 62%,
				rgba(255, 246, 237, 0.03) 100%
			),
			linear-gradient(
				0deg,
				rgba(20, 20, 20, 0.15) 0%,
				transparent 35%
			);
	}

	.hero-slide__container {
		position: relative;
		z-index: 2;
		width: min(calc(100% - 80px), 1440px);
		height: 100%;
		margin-inline: auto;
		display: flex;
		align-items: center;
	}

	.hero-slide__content {
	width: min(640px, 52%);
	padding: 210px 0 120px;
	color: #fff6ed;
}

	.hero-slide--light .hero-slide__content {
		color: #141414;
	}

	.hero-slide__eyebrow {
		margin: 0 0 24px;
		display: flex;
		align-items: center;
		gap: 14px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.hero-slide__eyebrow::before {
		content: "";
		width: 36px;
		height: 1px;
		background: currentColor;
		opacity: 0.7;
	}

	.hero-slide h1,
	.hero-slide h2 {
		max-width: 720px;
		margin: 0;
		font-size: clamp(46px, 5.5vw, 88px);
		font-weight: 700;
		line-height: 0.96;
		letter-spacing: -0.055em;
		text-wrap: balance;
	}

	.hero-slide__description {
		max-width: 560px;
		margin: 28px 0 34px;
		font-size: clamp(16px, 1.3vw, 20px);
		line-height: 1.6;
		opacity: 0.86;
	}

	.hero-slide__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		min-height: 56px;
		padding: 0 26px;
		border: 1px solid rgba(255, 246, 237, 0.45);
		background: #fff6ed;
		color: #141414;
		font-size: 12px;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			background-color 200ms ease,
			border-color 200ms ease,
			color 200ms ease,
			transform 200ms ease;
	}

	.hero-slide--light .hero-slide__button {
		border-color: #141414;
		background: #141414;
		color: #fff6ed;
	}

	.hero-slide__button svg {
		width: 19px;
		height: 19px;
		transition: transform 200ms ease;
	}

	.hero-slide__button:hover {
		border-color: #ff4d2a;
		background: #ff4d2a;
		color: #141414;
		transform: translateY(-2px);
	}

	.hero-slide__button:hover svg {
		transform: translateX(4px);
	}

	.hero-slide__trust {
		margin-top: 44px;
		display: flex;
		flex-wrap: wrap;
		gap: 10px 24px;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		opacity: 0.76;
	}

	.hero-slide__trust span {
		display: inline-flex;
		align-items: center;
		gap: 9px;
	}

	.hero-slide__trust span::before {
		content: "";
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: #ff4d2a;
	}

	.hero-slider__arrow {
		position: absolute;
		top: 50%;
		z-index: 4;
		width: 52px;
		height: 52px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.32);
		border-radius: 50%;
		background: rgba(20, 20, 20, 0.18);
		color: #fff;
		backdrop-filter: blur(10px);
		cursor: pointer;
		transform: translateY(-50%);
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.hero-slider__arrow:hover {
		border-color: #fff;
		background: rgba(20, 20, 20, 0.72);
	}

	.hero-slider__arrow--previous {
		left: 22px;
	}

	.hero-slider__arrow--next {
		right: 22px;
	}

	.hero-slider__arrow svg {
		width: 22px;
		height: 22px;
	}

	.hero-slider__pagination {
		position: absolute;
		z-index: 5;
		right: 50%;
		bottom: 42px;
		display: flex;
		align-items: center;
		gap: 10px;
		transform: translateX(50%);
	}

	.hero-slider__dot {
		width: 34px;
		height: 18px;
		padding: 0;
		display: grid;
		place-items: center;
		border: 0;
		background: transparent;
		cursor: pointer;
	}

	.hero-slider__dot span {
		display: block;
		width: 100%;
		height: 2px;
		background: rgba(255, 255, 255, 0.4);
		transition:
			background-color 180ms ease,
			transform 180ms ease;
	}

	.hero-slider__dot.is-active span {
		background: #ff4d2a;
		transform: scaleY(2);
	}

	.hero-slider__counter {
		position: absolute;
		right: max(40px, calc((100% - 1440px) / 2));
		bottom: 38px;
		z-index: 5;
		display: flex;
		align-items: center;
		gap: 10px;
		color: #fff;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 0.1em;
	}

	.hero-slider__counter-line {
		width: 28px;
		height: 1px;
		background: currentColor;
		opacity: 0.5;
	}

	.hero-slider__progress {
		position: absolute;
		right: 0;
		bottom: 0;
		z-index: 6;
		width: 100%;
		height: 3px;
		background: #ff4d2a;
		transform: scaleX(0);
		transform-origin: left;
	}

	.hero-slider__progress.is-running {
		animation: slider-progress 6s linear forwards;
	}

	.hero-slide__eyebrow,
	.hero-slide h1,
	.hero-slide h2,
	.hero-slide__description,
	.hero-slide__button,
	.hero-slide__trust {
		opacity: 0;
		transform: translateY(22px);
		transition:
			opacity 600ms ease,
			transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.hero-slide.is-active .hero-slide__eyebrow,
	.hero-slide.is-active h1,
	.hero-slide.is-active h2,
	.hero-slide.is-active .hero-slide__description,
	.hero-slide.is-active .hero-slide__button,
	.hero-slide.is-active .hero-slide__trust {
		opacity: 1;
		transform: translateY(0);
	}

	.hero-slide.is-active h1,
	.hero-slide.is-active h2 {
		transition-delay: 100ms;
	}

	.hero-slide.is-active .hero-slide__description {
		transition-delay: 180ms;
	}

	.hero-slide.is-active .hero-slide__button {
		transition-delay: 240ms;
	}

	.hero-slide.is-active .hero-slide__trust {
		transition-delay: 300ms;
	}

	@keyframes slider-progress {
		from {
			transform: scaleX(0);
		}

		to {
			transform: scaleX(1);
		}
	}

	@media (max-width: 900px) {
		.hero-slider__viewport {
			height: calc(100svh - 104px);
			min-height: 620px;
			max-height: 820px;
		}

		.hero-slide__container {
			width: min(calc(100% - 48px), 1440px);
			align-items: flex-end;
		}

		.hero-slide__content {
			width: 80%;
			padding: 180px 0 130px;
		}

		.hero-slide__overlay,
		.hero-slide--light .hero-slide__overlay {
			background:
				linear-gradient(
					0deg,
					rgba(12, 9, 8, 0.94) 0%,
					rgba(12, 9, 8, 0.72) 45%,
					rgba(12, 9, 8, 0.12) 82%
				);
		}

		.hero-slide--light .hero-slide__content {
			color: #fff6ed;
		}

		.hero-slide--light .hero-slide__button {
			border-color: #fff6ed;
			background: #fff6ed;
			color: #141414;
		}

		.hero-slider__arrow {
			display: none;
		}

		.hero-slider__counter {
			right: 24px;
		}
	}

	@media (max-width: 620px) {
		.hero-slider__viewport {
			height: calc(100svh - 104px);
			min-height: 600px;
			max-height: 760px;
		}

		.hero-slide__image {
			object-position: center;
		}

		.hero-slide__container {
			width: min(calc(100% - 36px), 1440px);
		}

		.hero-slide__content {
	width: 100%;
	padding: 155px 0 110px;
}

		.hero-slide__eyebrow {
			margin-bottom: 18px;
			font-size: 9px;
		}

		.hero-slide h1,
		.hero-slide h2 {
			font-size: clamp(40px, 12vw, 58px);
		}

		.hero-slide__description {
			margin: 22px 0 28px;
			font-size: 15px;
			line-height: 1.55;
		}

		.hero-slide__button {
			width: 100%;
			min-height: 54px;
			padding-inline: 20px;
		}

		.hero-slide__trust {
			display: none;
		}

		.hero-slider__pagination {
			right: auto;
			bottom: 32px;
			left: 18px;
			transform: none;
		}

		.hero-slider__counter {
			right: 18px;
			bottom: 29px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-slide,
		.hero-slide__image,
		.hero-slide__eyebrow,
		.hero-slide h1,
		.hero-slide h2,
		.hero-slide__description,
		.hero-slide__button,
		.hero-slide__trust {
			transition: none;
		}

		.hero-slider__progress {
			display: none;
		}
	}
</style>