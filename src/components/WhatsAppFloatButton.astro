---
import { WHATSAPP_NUMBER } from "../lib/constants";

const base = import.meta.env.BASE_URL;

const whatsappMessage = encodeURIComponent(
	"Hola TAQTO, quisiera pedir información sobre sus productos.",
);

const whatsappHref =
	`https://wa.me/${WHATSAPP_NUMBER}?text=${whatsappMessage}`;

const isCartPage =
	Astro.url.pathname.includes("/carrito");
---

{
	!isCartPage && (
<a
	class="whatsapp-float"
	href={whatsappHref}
	target="_blank"
	rel="noopener noreferrer"
	aria-label="Pedir por WhatsApp"
>
	<img
		src={`${base}icons/icon-whastapp.svg`}
		alt=""
		width="26"
		height="26"
	/>

	<span class="whatsapp-float__label">Pedir por WhatsApp</span>
</a>
	)
}

<style>
	.whatsapp-float {
		position: fixed;
		right: clamp(14px, 3vw, 26px);
		bottom: clamp(14px, 3vw, 26px);
		z-index: 150;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 12px;
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 999px;
		background: rgba(3, 3, 3, 0.96);
		color: #fff6ed;
		text-decoration: none;
		box-shadow: 0 14px 34px rgba(0, 0, 0, 0.34);
		transition:
			transform 200ms ease,
			padding-inline-end 200ms ease,
			box-shadow 200ms ease;
	}

	.whatsapp-float:hover {
		transform: translateY(-3px);
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.4);
	}

	.whatsapp-float img {
		display: block;
		width: 26px;
		height: 26px;
		flex-shrink: 0;
	}

	.whatsapp-float__label {
		max-width: 0;
		overflow: hidden;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
		opacity: 0;
		transition:
			max-width 220ms ease,
			opacity 180ms ease;
	}

	@media (hover: hover) {
		.whatsapp-float:hover .whatsapp-float__label {
			max-width: 160px;
			opacity: 1;
		}

		.whatsapp-float:hover {
			padding-inline-end: 18px;
		}
	}

	@media (max-width: 680px) {
		.whatsapp-float {
			padding: 11px;
		}
	}
</style>
