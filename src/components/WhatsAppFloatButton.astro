---
import { WHATSAPP_NUMBER } from "../lib/constants";

const whatsappMessage = encodeURIComponent(
	"Hola TAQTO, quisiera pedir información sobre sus productos.",
);

const whatsappHref =
	`https://wa.me/${WHATSAPP_NUMBER}?text=${whatsappMessage}`;
---

<a
	class="whatsapp-float"
	href={whatsappHref}
	target="_blank"
	rel="noopener noreferrer"
	aria-label="Pedir por WhatsApp"
>
	<svg
		viewBox="0 0 24 24"
		aria-hidden="true"
		fill="none"
		stroke="currentColor"
		stroke-width="1.75"
	>
		<path d="M20.5 11.8a8.5 8.5 0 0 1-12.6 7.5L3.5 21l1.6-4.2a8.5 8.5 0 1 1 15.4-5Z"
		></path>
		<path d="M8.6 7.8c.2-.5.5-.6.8-.6h.5c.2 0 .4.1.5.4l.8 1.8c.1.3.1.5-.1.7l-.6.8c-.2.2-.2.4 0 .7.7 1.3 1.8 2.3 3.2 2.9.3.1.5.1.7-.1l.9-1.1c.2-.2.5-.3.8-.1l1.7.8c.3.1.4.4.4.7 0 .6-.3 1.5-.9 2-.7.6-1.6.8-2.6.6-1.3-.2-3-.9-4.8-2.5-1.5-1.3-2.6-2.9-3-4.1-.5-1.3-.1-2.4.3-3Z"
		></path>
	</svg>

	<span class="whatsapp-float__label">Pedir por WhatsApp</span>
</a>

<style>
	.whatsapp-float {
		position: fixed;
		right: clamp(14px, 3vw, 26px);
		bottom: clamp(14px, 3vw, 26px);
		z-index: 150;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 14px;
		border-radius: 999px;
		background: #25d366;
		color: #05210f;
		text-decoration: none;
		box-shadow: 0 14px 34px rgba(0, 0, 0, 0.28);
		transition:
			transform 200ms ease,
			padding-inline-end 200ms ease,
			box-shadow 200ms ease;
	}

	.whatsapp-float:hover {
		transform: translateY(-3px);
		box-shadow: 0 18px 42px rgba(0, 0, 0, 0.34);
	}

	.whatsapp-float svg {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
	}

	.whatsapp-float__label {
		max-width: 0;
		overflow: hidden;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.02em;
		white-space: nowrap;
		opacity: 0;
		transition:
			max-width 220ms ease,
			opacity 180ms ease;
	}

	@media (hover: hover) {
		.whatsapp-float:hover .whatsapp-float__label {
			max-width: 160px;
			opacity: 1;
		}

		.whatsapp-float:hover {
			padding-inline-end: 18px;
		}
	}

	@media (max-width: 680px) {
		.whatsapp-float {
			padding: 13px;
		}
	}
</style>
