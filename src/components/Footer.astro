---
const commercialLinks = [
	{ label: "Tienda", href: "/categorias/" },
	{ label: "Parrilla", href: "/categorias/parrilla/" },
	{ label: "Cocina y Mesa", href: "/categorias/cocina-y-mesa/" },
	{ label: "Oficina", href: "/categorias/oficina/" },
	{ label: "Kits y regalos", href: "/categorias/kits-y-regalos/" },
];

const companyLinks = [
	{ label: "Nosotros", href: "/nosotros/" },
	{ label: "Madera sostenible", href: "/madera-sostenible/" },
	{
		label: "Regalos corporativos",
		href: "/categorias/empresas/regalos-corporativos/",
	},
	{
		label: "Ventas al por mayor",
		href: "/categorias/empresas/ventas-al-por-mayor/",
	},
	{ label: "Blog", href: "/blog/" },
];

const supportLinks = [
	{ label: "Contáctanos", href: "/contactanos/" },
	{ label: "Preguntas frecuentes", href: "/preguntas-frecuentes/" },
	{ label: "Cuidados", href: "/cuidados/" },
	{ label: "Envíos", href: "/envios/" },
	{ label: "Cambios y devoluciones", href: "/cambios-y-devoluciones/" },
];

const legalLinks = [
	{ label: "Términos y condiciones", href: "/terminos-y-condiciones/" },
	{ label: "Privacidad", href: "/privacidad/" },
];

/*
	Reemplaza estas tres URLs por las redes reales de TAQTO.
	No dejes los textos TU_URL... al publicar la página.
*/
const socialLinks = [
	{
		label: "Instagram",
		href: "TU_URL_DE_INSTAGRAM",
		icon: "instagram",
	},
	{
		label: "Facebook",
		href: "TU_URL_DE_FACEBOOK",
		icon: "facebook",
	},
	{
		label: "TikTok",
		href: "TU_URL_DE_TIKTOK",
		icon: "tiktok",
	},
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-shell">
		<div class="footer-glow" aria-hidden="true"></div>

		<div class="footer-top">
			<div class="footer-top__content">
				<p class="footer-eyebrow">
					Neo-Artesanía Peruana de Precisión
				</p>

				<h2>Diseño hecho para permanecer.</h2>

				<p class="footer-top__description">
					Piezas de madera y cuero creadas para regalar,
					compartir y acompañar tu día a día.
				</p>
			</div>

			<a class="footer-cta" href="/contactanos/">
				<span>Conversemos</span>

				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="M5 12h14"></path>
					<path d="m14 7 5 5-5 5"></path>
				</svg>
			</a>
		</div>

		<div class="footer-divider"></div>

		<div class="footer-main">
			<div class="footer-brand">
				<a
					class="footer-logo"
					href="/"
					aria-label="TAQTO, volver al inicio"
				>
					<span class="footer-logo__name">TAQTO</span>

					<span class="footer-logo__tagline">
						Diseño con alma de madera
					</span>
				</a>

				<p class="footer-brand__description">
					Piezas peruanas creadas con precisión,
					oficio y una mirada contemporánea.
				</p>

				<div class="footer-socials" aria-label="Redes sociales">
					{
						socialLinks.map((social) => (
							<a
								class="social-link"
								href={social.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={social.label}
							>
								{
									social.icon === "instagram" && (
										<svg
											viewBox="0 0 24 24"
											aria-hidden="true"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
										>
											<rect
												x="3"
												y="3"
												width="18"
												height="18"
												rx="5"
											/>
											<circle cx="12" cy="12" r="4" />
											<circle
												cx="17.5"
												cy="6.5"
												r="0.8"
												fill="currentColor"
												stroke="none"
											/>
										</svg>
									)
								}

								{
									social.icon === "facebook" && (
										<svg
											viewBox="0 0 24 24"
											aria-hidden="true"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
										>
											<path d="M14 8h4V3h-4c-3 0-5 2-5 5v3H6v5h3v5h5v-5h4l1-5h-5V8Z" />
										</svg>
									)
								}

								{
									social.icon === "tiktok" && (
										<svg
											viewBox="0 0 24 24"
											aria-hidden="true"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
										>
											<path d="M15 4v10.2a4.8 4.8 0 1 1-4-4.7" />
											<path d="M15 4c.6 2.7 2.2 4.3 5 4.8" />
										</svg>
									)
								}
							</a>
						))
					}
				</div>

				<div class="footer-benefit">
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.7"
					>
						<path d="M12 3 14.3 8.7 20 11l-5.7 2.3L12 19l-2.3-5.7L4 11l5.7-2.3L12 3Z"></path>
					</svg>

					<div>
						<strong>Grabado láser gratuito</strong>
						<small>Incluido en madera y cuero.</small>
					</div>
				</div>
			</div>

			<nav class="footer-navigation" aria-label="Navegación del pie">
				<div class="footer-column">
					<h3>Comprar</h3>

					<ul>
						{
							commercialLinks.map((item) => (
								<li>
									<a href={item.href}>{item.label}</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="footer-column">
					<h3>TAQTO</h3>

					<ul>
						{
							companyLinks.map((item) => (
								<li>
									<a href={item.href}>{item.label}</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="footer-column">
					<h3>Ayuda</h3>

					<ul>
						{
							supportLinks.map((item) => (
								<li>
									<a href={item.href}>{item.label}</a>
								</li>
							))
						}
					</ul>
				</div>
			</nav>
		</div>

		<div class="footer-divider footer-divider--small"></div>

		<div class="footer-business">
			<div>
				<span>Empresas</span>

				<p>
					Regalos corporativos y pedidos al por mayor
					con atención consultiva y mockup previo.
				</p>
			</div>

			<p class="footer-business__rule">
				El sello TAQTO siempre permanece junto al logotipo del cliente.
			</p>
		</div>

		<div class="footer-divider footer-divider--small"></div>

		<div class="footer-bottom">
			<p>© {currentYear} TAQTO. Todos los derechos reservados.</p>

			<ul>
				{
					legalLinks.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>

			<a class="footer-back-top" href="#top">
				<span>Volver arriba</span>

				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="m7 14 5-5 5 5"></path>
				</svg>
			</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding:
			clamp(54px, 7vw, 90px)
			clamp(10px, 2vw, 28px)
			14px;
		background: var(--color-beige, #fff6ed);
		color: #fff6ed;
	}

	.footer-shell {
		position: relative;
		width: min(100%, 1540px);
		margin-inline: auto;
		padding:
			clamp(34px, 4vw, 58px)
			clamp(24px, 4.5vw, 68px)
			24px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 30px;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.045),
				rgba(255, 255, 255, 0.008) 45%,
				rgba(91, 49, 42, 0.04)
			),
			rgba(5, 5, 5, 0.97);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.09),
			0 24px 60px rgba(20, 20, 20, 0.19);
		backdrop-filter: blur(24px) saturate(120%);
		-webkit-backdrop-filter: blur(24px) saturate(120%);
	}

	.footer-shell::before {
		content: "";
		position: absolute;
		top: 0;
		right: 8%;
		left: 8%;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.34),
			transparent
		);
	}

	.footer-glow {
		position: absolute;
		top: -190px;
		right: -110px;
		width: 430px;
		height: 430px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(91, 49, 42, 0.2),
			transparent 68%
		);
		pointer-events: none;
	}

	.footer-top,
	.footer-main,
	.footer-business,
	.footer-bottom,
	.footer-divider {
		position: relative;
		z-index: 1;
	}

	.footer-top {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: end;
		gap: 50px;
	}

	.footer-top__content {
		max-width: 770px;
	}

	.footer-eyebrow {
		margin: 0 0 14px;
		color: #ff4d2a;
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.footer-top h2 {
		max-width: 750px;
		margin: 0;
		font-size: clamp(38px, 5vw, 70px);
		font-weight: 500;
		line-height: 0.94;
		letter-spacing: -0.05em;
		text-wrap: balance;
	}

	.footer-top__description {
		max-width: 590px;
		margin: 18px 0 0;
		color: rgba(255, 246, 237, 0.56);
		font-size: 15px;
		line-height: 1.6;
	}

	.footer-cta {
		min-height: 54px;
		padding: 0 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 22px;
		border-radius: 14px;
		background: #fff6ed;
		color: #141414;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
		transition:
			background-color 180ms ease,
			transform 180ms ease;
	}

	.footer-cta:hover {
		background: #ff4d2a;
		transform: translateY(-2px);
	}

	.footer-cta svg {
		width: 19px;
		height: 19px;
		transition: transform 180ms ease;
	}

	.footer-cta:hover svg {
		transform: translateX(4px);
	}

	.footer-divider {
		height: 1px;
		margin-block: clamp(32px, 4vw, 48px);
		background: rgba(255, 255, 255, 0.085);
	}

	.footer-divider--small {
		margin-block: 28px;
	}

	.footer-main {
		display: grid;
		grid-template-columns: minmax(250px, 0.7fr) 1.5fr;
		gap: clamp(55px, 9vw, 150px);
	}

	.footer-brand {
		max-width: 370px;
	}

	.footer-logo {
		display: inline-flex;
		flex-direction: column;
		color: inherit;
		text-decoration: none;
	}

	.footer-logo__name {
		font-size: 38px;
		font-weight: 700;
		line-height: 0.9;
		letter-spacing: -0.06em;
	}

	.footer-logo__tagline {
		margin-top: 8px;
		color: rgba(255, 246, 237, 0.4);
		font-size: 8px;
		font-weight: 600;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.footer-brand__description {
		margin: 22px 0 20px;
		color: rgba(255, 246, 237, 0.55);
		font-size: 13px;
		line-height: 1.65;
	}

	.footer-socials {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-bottom: 20px;
	}

	.social-link {
		width: 39px;
		height: 39px;
		display: grid;
		place-items: center;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.025);
		color: rgba(255, 246, 237, 0.7);
		text-decoration: none;
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.social-link:hover {
		border-color: rgba(255, 255, 255, 0.22);
		background: rgba(255, 255, 255, 0.08);
		color: #fff6ed;
		transform: translateY(-2px);
	}

	.social-link svg {
		width: 18px;
		height: 18px;
	}

	.footer-benefit {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 13px 14px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 14px;
		background: rgba(255, 255, 255, 0.025);
	}

	.footer-benefit > svg {
		flex: 0 0 auto;
		width: 20px;
		height: 20px;
		color: #ff4d2a;
	}

	.footer-benefit div {
		display: flex;
		flex-direction: column;
		gap: 3px;
	}

	.footer-benefit strong {
		font-size: 11.5px;
		font-weight: 600;
	}

	.footer-benefit small {
		color: rgba(255, 246, 237, 0.43);
		font-size: 10px;
	}

	.footer-navigation {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(30px, 5vw, 70px);
	}

	.footer-column h3 {
		margin: 0 0 20px;
		color: rgba(255, 246, 237, 0.4);
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	.footer-column ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.footer-column li + li {
		margin-top: 13px;
	}

	.footer-column a {
		display: inline-flex;
		color: rgba(255, 246, 237, 0.72);
		font-size: 12.5px;
		font-weight: 500;
		line-height: 1.4;
		text-decoration: none;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.footer-column a:hover {
		color: #fff6ed;
		transform: translateX(4px);
	}

	.footer-business {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: clamp(45px, 8vw, 130px);
	}

	.footer-business span {
		display: block;
		margin-bottom: 8px;
		color: #ff4d2a;
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.footer-business p {
		margin: 0;
		color: rgba(255, 246, 237, 0.6);
		font-size: 12.5px;
		line-height: 1.6;
	}

	.footer-business__rule {
		padding-left: 20px;
		border-left: 2px solid #5b312a;
		color: rgba(255, 246, 237, 0.75) !important;
	}

	.footer-bottom {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 28px;
		color: rgba(255, 246, 237, 0.4);
		font-size: 9px;
		font-weight: 500;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-bottom ul {
		display: flex;
		gap: 22px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.footer-bottom a {
		color: inherit;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.footer-bottom a:hover {
		color: #fff6ed;
	}

	.footer-back-top {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.footer-back-top svg {
		width: 15px;
		height: 15px;
	}

	@media (max-width: 940px) {
		.footer-top {
			grid-template-columns: 1fr;
			align-items: start;
			gap: 28px;
		}

		.footer-cta {
			justify-self: start;
		}

		.footer-main {
			grid-template-columns: 1fr;
		}

		.footer-brand {
			max-width: 520px;
		}

		.footer-bottom {
			grid-template-columns: 1fr auto;
		}

		.footer-bottom ul {
			grid-column: 1 / -1;
			grid-row: 1;
		}
	}

	@media (max-width: 680px) {
		.site-footer {
			padding:
				46px
				8px
				8px;
		}

		.footer-shell {
			padding:
				34px
				20px
				22px;
			border-radius: 23px;
		}

		.footer-top h2 {
			font-size: clamp(39px, 11vw, 54px);
		}

		.footer-cta {
			width: 100%;
		}

		.footer-navigation {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 38px 26px;
		}

		.footer-column:last-child {
			grid-column: 1 / -1;
		}

		.footer-business {
			grid-template-columns: 1fr;
			gap: 22px;
		}

		.footer-bottom {
			display: flex;
			align-items: flex-start;
			flex-direction: column;
			gap: 18px;
		}

		.footer-bottom ul {
			flex-direction: column;
			gap: 11px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.footer-cta,
		.footer-cta svg,
		.footer-column a,
		.social-link {
			transition: none;
		}
	}
</style>