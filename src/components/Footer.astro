---
import { sanityClient } from "../lib/sanity";
import { navigationCategoriesQuery } from "../lib/categoryQueries";
import { WHATSAPP_NUMBER } from "../lib/constants";

interface Props {
	whatsappNumber?: string;
	whatsappMessage?: string;
}

const {
	whatsappNumber = WHATSAPP_NUMBER,
	whatsappMessage =
		"Hola TAQTO, quisiera información sobre sus productos.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const getUrl = (path: string) =>
	`${base}${path.startsWith("/") ? path : `/${path}`}`;

const footerLogo =
	`${base}/brand/imagotipo/imagotipo-colorprincipal02.svg`;

interface FooterSubcategory {
	_id: string;
	title: string;
	slug: string;
}

interface FooterCategory {
	_id: string;
	title: string;
	slug: string;
	subcategories?: FooterSubcategory[];
}

const navCategories =
	await sanityClient.fetch<FooterCategory[]>(
		navigationCategoriesQuery,
	);

const empresasCategory = navCategories.find(
	(category) => category.slug === "empresas",
);

/* 1. COMPRAR */
const shoppingLinks = navCategories
	.filter((category) => category.slug !== "empresas")
	.map((category) => ({
		label: category.title,
		href: getUrl(`/categorias/${category.slug}/`),
	}));

/* 2. EMPRESAS */
const businessLinks = (
	empresasCategory?.subcategories || []
).map((subcategory) => ({
	label: subcategory.title,
	href: getUrl(
		`/categorias/empresas/${subcategory.slug}/`,
	),
}));

/* 3. INFORMACIÓN */
const informationLinks = [
	{
		label: "Nosotros",
		href: getUrl("/nosotros/"),
	},
	{
		label: "Madera sostenible",
		href: getUrl("/madera-sostenible/"),
	},
	{
		label: "Contáctanos",
		href: getUrl("/contactanos/"),
	},
	{
		label: "Blog",
		href: getUrl("/blog/"),
	},
];

/* 4. AYUDA */
const helpLinks = [
	{
		label: "Cuidados",
		href: getUrl("/cuidados/"),
	},
	{
		label: "Política de envíos",
		href: getUrl("/envios/"),
	},
	{
		label: "Política de privacidad",
		href: getUrl("/privacidad/"),
	},
	{
		label: "Preguntas frecuentes",
		href: getUrl("/preguntas-frecuentes/"),
	},
	{
		label: "Términos y condiciones",
		href: getUrl("/terminos-y-condiciones/"),
	},
	{
		label: "Cambios y devoluciones",
		href: getUrl("/cambios-y-devoluciones/"),
	},
];

const legalLinks = [
	{
		label: "Términos y condiciones",
		href: getUrl("/terminos-y-condiciones/"),
	},
	{
		label: "Política de privacidad",
		href: getUrl("/privacidad/"),
	},
];

const formattedWhatsappMsg =
	encodeURIComponent(whatsappMessage);

const whatsappUrl =
	`https://wa.me/${whatsappNumber}?text=${formattedWhatsappMsg}`;

const socialLinks = [
	{
		label: "Instagram",
		href: "https://instagram.com/",
		icon: "instagram",
	},
	{
		label: "Facebook",
		href: "https://facebook.com/",
		icon: "facebook",
	},
	{
		label: "TikTok",
		href: "https://tiktok.com/",
		icon: "tiktok",
	},
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-shell">
		<div
			class="footer-glow"
			aria-hidden="true"
		></div>

		<section class="footer-heading">
			<div class="footer-heading__text">
				<p class="footer-eyebrow">
					Neo-Artesanía Peruana de Precisión
				</p>

				<h2>
					Diseño hecho para permanecer.
				</h2>

				<p class="footer-heading__description">
					Piezas de madera y cuero creadas para
					regalar, compartir y acompañar tu día a día.
				</p>
			</div>

			<a
				class="footer-contact"
				href={getUrl("/contactanos/")}
			>
				<span>Conversemos</span>

				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
				>
					<path d="M5 12h14"></path>
					<path d="m14 7 5 5-5 5"></path>
				</svg>
			</a>
		</section>

		<div class="footer-divider"></div>

		<section class="footer-content">
			<div class="footer-brand">
				<a
					class="footer-logo"
					href={getUrl("/")}
					aria-label="TAQTO, volver al inicio"
				>
					<img
						src={footerLogo}
						alt="TAQTO — Diseño con alma de madera"
						width="185"
						height="139"
						loading="lazy"
						decoding="async"
					/>
				</a>

				<p class="footer-brand__description">
					Piezas peruanas de madera y cuero creadas
					con precisión, oficio y una mirada
					contemporánea.
				</p>

				<div
					class="footer-socials"
					aria-label="Redes sociales de TAQTO"
				>
					{
						socialLinks.map((social) => (
							<a
								class="social-button"
								href={social.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={social.label}
							>
								{social.icon === "instagram" && (
									<svg
										viewBox="0 0 24 24"
										aria-hidden="true"
										class="icon-stroke"
									>
										<rect
											x="3"
											y="3"
											width="18"
											height="18"
											rx="5"
										></rect>

										<circle
											cx="12"
											cy="12"
											r="4"
										></circle>

										<circle
											cx="17.5"
											cy="6.5"
											r="0.8"
											class="social-dot"
										></circle>
									</svg>
								)}

								{social.icon === "facebook" && (
									<svg
										viewBox="0 0 24 24"
										aria-hidden="true"
										class="icon-fill"
									>
										<path d="M14 8h4V3h-4c-3 0-5 2-5 5v3H6v5h3v5h5v-5h4l1-5h-5V8Z"></path>
									</svg>
								)}

								{social.icon === "tiktok" && (
									<svg
										viewBox="0 0 24 24"
										aria-hidden="true"
										class="icon-fill"
									>
										<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 1 1-2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 1 0 5.55 6.29V9.11a8.3 8.3 0 0 0 4.22 1.13V6.76a4.8 4.8 0 0 1-.45-.07z"></path>
									</svg>
								)}
							</a>
						))
					}
				</div>

				<a
					class="whatsapp-button"
					href={whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="whatsapp-button__icon">
						<img
							src={getUrl("/icons/icon-whastapp.svg")}
							alt=""
							width="24"
							height="24"
						/>
					</span>

					<span class="whatsapp-button__text">
						<small>
							Atención personalizada
						</small>

						<strong>
							Escríbenos por WhatsApp
						</strong>
					</span>

					<svg
						class="whatsapp-button__arrow"
						viewBox="0 0 24 24"
						aria-hidden="true"
					>
						<path d="M5 12h14"></path>
						<path d="m14 7 5 5-5 5"></path>
					</svg>
				</a>
			</div>

			<nav
				class="footer-navigation"
				aria-label="Navegación del pie de página"
			>
				<div class="footer-column">
					<h3>Comprar</h3>

					<ul>
						{
							shoppingLinks.map((item) => (
								<li>
									<a href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="footer-column">
					<h3>Empresas</h3>

					<ul>
						{
							businessLinks.map((item) => (
								<li>
									<a href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="footer-column">
					<h3>Información</h3>

					<ul>
						{
							informationLinks.map((item) => (
								<li>
									<a href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>

				<div class="footer-column">
					<h3>Ayuda</h3>

					<ul>
						{
							helpLinks.map((item) => (
								<li>
									<a href={item.href}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</nav>
		</section>

		<div
			class="footer-divider footer-divider--small"
		></div>

		<section class="footer-business">
			<div>
				<span>Empresas</span>

				<p>
					Regalos corporativos y pedidos al por mayor
					con atención consultiva y mockup previo.
				</p>
			</div>

			<p class="footer-business__rule">
				El sello TAQTO siempre permanece junto al
				logotipo del cliente.
			</p>
		</section>

		<div
			class="footer-divider footer-divider--small"
		></div>

		<section class="footer-bottom">
			<p>
				© {currentYear} TAQTO. Todos los derechos
				reservados.
			</p>

			<ul>
				{
					legalLinks.map((item) => (
						<li>
							<a href={item.href}>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>

			<a
				class="footer-back-top"
				href="#top"
			>
				<span>Volver arriba</span>

				<svg
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path d="m7 14 5-5 5 5"></path>
				</svg>
			</a>
		</section>
	</div>
</footer>

<style>
	.site-footer {
		padding:
			clamp(50px, 7vw, 86px)
			clamp(10px, 2vw, 28px)
			14px;
		background: var(--color-beige, #fff6ed);
		color: #fff6ed;
	}

	/* MISMO TONO Y EFECTO DEL HEADER */
	.footer-shell {
		position: relative;
		width: min(100%, 1540px);
		margin-inline: auto;
		padding:
			clamp(34px, 4vw, 56px)
			clamp(24px, 4.5vw, 68px)
			24px;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 30px;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.04),
				rgba(255, 255, 255, 0.008) 46%,
				rgba(91, 49, 42, 0.025)
			),
			rgba(3, 3, 3, 0.985);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 24px 68px rgba(0, 0, 0, 0.48);
		backdrop-filter: blur(28px) saturate(115%);
		-webkit-backdrop-filter: blur(28px) saturate(115%);
	}

	.footer-shell::before {
		content: "";
		position: absolute;
		top: 0;
		right: 8%;
		left: 8%;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.35),
			transparent
		);
		pointer-events: none;
	}

	.footer-glow {
		position: absolute;
		top: -190px;
		right: -100px;
		width: 430px;
		height: 430px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(91, 49, 42, 0.14),
			transparent 68%
		);
		pointer-events: none;
	}

	.footer-heading,
	.footer-content,
	.footer-business,
	.footer-bottom,
	.footer-divider {
		position: relative;
		z-index: 1;
	}

	.footer-heading {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 32px;
	}

	.footer-heading__text {
		max-width: 720px;
	}

	.footer-eyebrow {
		margin: 0 0 12px;
		color: #ff4d2a;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.footer-heading h2 {
		margin: 0;
		font-size: clamp(28px, 3.5vw, 44px);
		font-weight: 500;
		line-height: 1.05;
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	.footer-heading__description {
		max-width: 580px;
		margin: 14px 0 0;
		color: rgba(255, 246, 237, 0.62);
		font-size: 14px;
		line-height: 1.55;
	}

	.footer-contact {
		min-height: 52px;
		padding: 0 24px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		flex-shrink: 0;
		border-radius: 14px;
		background: #fff6ed;
		color: #141414;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
		transition:
			background-color 180ms ease,
			transform 180ms ease;
	}

	.footer-contact:hover {
		background: #ff4d2a;
		transform: translateY(-2px);
	}

	.footer-contact svg {
		width: 18px;
		height: 18px;
	}

	.footer-divider {
		height: 1px;
		margin-block: clamp(28px, 3.5vw, 40px);
		background: rgba(255, 255, 255, 0.1);
	}

	.footer-divider--small {
		margin-block: 27px;
	}

	.footer-content {
		display: grid;
		grid-template-columns: 320px minmax(0, 1fr);
		align-items: start;
		gap: clamp(40px, 5vw, 78px);
	}

	.footer-brand {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.footer-logo {
		display: flex;
		justify-content: center;
		width: 100%;
		color: inherit;
		text-decoration: none;
	}

	.footer-logo img {
		display: block;
		width: 165px;
		height: auto;
		object-fit: contain;
	}

	.footer-brand__description {
		max-width: 300px;
		margin: 16px 0;
		color: rgba(255, 246, 237, 0.62);
		font-size: 13px;
		line-height: 1.6;
		text-align: center;
	}

	.footer-socials {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin-bottom: 18px;
	}

	.social-button {
		width: 40px;
		height: 40px;
		flex: 0 0 40px;
		display: grid;
		place-items: center;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.025);
		color: rgba(255, 246, 237, 0.78);
		text-decoration: none;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.social-button:hover {
		background: rgba(255, 255, 255, 0.09);
		color: #fff6ed;
		transform: translateY(-2px);
	}

	.social-button svg {
		display: block;
		width: 18px;
		height: 18px;
	}

	.social-button .icon-stroke {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.7;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.social-button .icon-fill {
		fill: currentColor;
		stroke: none;
	}

	.social-button .social-dot {
		fill: currentColor;
		stroke: none;
	}

	.whatsapp-button {
		width: 100%;
		max-width: 320px;
		min-height: 58px;
		padding: 10px 14px;
		display: grid;
		grid-template-columns:
			38px
			minmax(0, 1fr)
			18px;
		align-items: center;
		gap: 12px;
		overflow: hidden;
		border: 1px solid rgba(37, 211, 102, 0.22);
		border-radius: 14px;
		background: rgba(37, 211, 102, 0.07);
		color: #fff6ed;
		text-align: left;
		text-decoration: none;
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			transform 180ms ease;
	}

	.whatsapp-button:hover {
		border-color: rgba(37, 211, 102, 0.52);
		background: rgba(37, 211, 102, 0.13);
		transform: translateY(-2px);
	}

	.whatsapp-button__icon {
		width: 38px;
		height: 38px;
		display: grid;
		place-items: center;
	}

	.whatsapp-button__icon img {
		display: block;
		width: 30px;
		height: 30px;
	}

	.whatsapp-button__text {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.whatsapp-button__text small {
		color: rgba(255, 246, 237, 0.5);
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.whatsapp-button__text strong {
		overflow: hidden;
		font-size: 12px;
		font-weight: 600;
		white-space: nowrap;
		text-overflow: ellipsis;
	}

	.whatsapp-button__arrow {
		display: block;
		width: 18px;
		height: 18px;
		fill: none;
		stroke: rgba(255, 246, 237, 0.6);
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
		transition: transform 180ms ease;
	}

	.whatsapp-button:hover
		.whatsapp-button__arrow {
		transform: translateX(3px);
	}

	/* CUATRO COLUMNAS COMO LA REFERENCIA */
	.footer-navigation {
		width: 100%;
		display: grid;
		grid-template-columns:
			repeat(4, minmax(0, 1fr));
		align-items: start;
		gap: clamp(18px, 2.8vw, 42px);
		padding-top: 4px;
	}

	.footer-column h3 {
		margin: 0 0 20px;
		color: rgba(255, 246, 237, 0.48);
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.footer-column ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.footer-column li + li {
		margin-top: 14px;
	}

	.footer-column a {
		display: inline-flex;
		color: rgba(255, 246, 237, 0.78);
		font-size: 13.5px;
		font-weight: 500;
		line-height: 1.45;
		text-decoration: none;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.footer-column a:hover {
		color: #fff6ed;
		transform: translateX(4px);
	}

	.footer-business {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: clamp(45px, 8vw, 130px);
	}

	.footer-business span {
		display: block;
		margin-bottom: 8px;
		color: #ff4d2a;
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
	}

	.footer-business p {
		margin: 0;
		color: rgba(255, 246, 237, 0.64);
		font-size: 12.5px;
		line-height: 1.6;
	}

	.footer-business__rule {
		padding-left: 20px;
		border-left: 2px solid #5b312a;
		color: rgba(255, 246, 237, 0.78) !important;
	}

	.footer-bottom {
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 28px;
		color: rgba(255, 246, 237, 0.48);
		font-size: 11px;
		font-weight: 500;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.footer-bottom p {
		margin: 0;
	}

	.footer-bottom ul {
		display: flex;
		gap: 22px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.footer-bottom a {
		color: inherit;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.footer-bottom a:hover {
		color: #fff6ed;
	}

	.footer-back-top {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.footer-back-top svg {
		display: block;
		width: 15px;
		height: 15px;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	/* TABLET */
	@media (max-width: 1180px) {
		.footer-content {
			grid-template-columns: 280px minmax(0, 1fr);
			gap: 42px;
		}

		.footer-navigation {
			grid-template-columns:
				repeat(2, minmax(0, 1fr));
			gap: 40px 36px;
		}
	}

	@media (max-width: 980px) {
		.footer-heading {
			flex-direction: column;
			align-items: flex-start;
			gap: 24px;
		}

