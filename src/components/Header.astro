---
import { sanityClient } from "../lib/sanity";
import { navigationCategoriesQuery } from "../lib/categoryQueries";
import { WHATSAPP_NUMBER } from "../lib/constants";

interface NavSubcategory {
	_id: string;
	title: string;
	slug: string;
}

interface NavCategory {
	_id: string;
	title: string;
	eyebrow?: string;
	slug: string;
	subcategories?: NavSubcategory[];
}

const productCategories =
	await sanityClient.fetch<NavCategory[]>(
		navigationCategoriesQuery,
	);

const base = import.meta.env.BASE_URL;

const withBase = (path = "") =>
	`${base}${path.replace(/^\/+/, "")}`;

const basePath =
	base === "/"
		? ""
		: base.replace(/\/$/, "");

const currentPath =
	Astro.url.pathname.startsWith(basePath)
		? Astro.url.pathname.slice(basePath.length) || "/"
		: Astro.url.pathname;

const homeHref = withBase();
const storeHref = withBase("categorias/");
const contactHref = withBase("contactanos/");
const searchHref = withBase("buscar/");
const accountHref = withBase("mi-cuenta/");
const cartHref = withBase("carrito/");

const headerLogo =
	`${base}brand/logotipo/logotipo-colorprincipal02.svg`;

const mobileLogo =
	`${base}brand/isotipo/isotipo-colorprincipal02.svg`;

const whatsappMessage = encodeURIComponent(
	"Hola TAQTO, quisiera información sobre sus productos.",
);

const whatsappHref =
	`https://wa.me/${WHATSAPP_NUMBER}?text=${whatsappMessage}`;

const categoryIcons: Record<string, string> = {
	parrilla: `
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path d="M5 11h14"></path>
			<path d="M7 11v4a5 5 0 0 0 10 0v-4"></path>
			<path d="M9 19l-1 3"></path>
			<path d="M15 19l1 3"></path>
			<path d="M9 7c0-1 1-1.5 1-2.5"></path>
			<path d="M13 7c0-1 1-1.5 1-2.5"></path>
		</svg>
	`,
	"cocina-y-mesa": `
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<circle cx="12" cy="12" r="7"></circle>
			<circle cx="12" cy="12" r="3"></circle>
			<path d="M4 4v7"></path>
			<path d="M2.5 7h3"></path>
			<path d="M20 4v16"></path>
		</svg>
	`,
	oficina: `
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<rect x="3" y="5" width="18" height="13" rx="2"></rect>
			<path d="M8 22h8"></path>
			<path d="M12 18v4"></path>
		</svg>
	`,
	"kits-y-regalos": `
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<rect x="3" y="9" width="18" height="12" rx="1.5"></rect>
			<path d="M12 9v12"></path>
			<path d="M3 13h18"></path>
			<path d="M12 9H8.5A2.5 2.5 0 1 1 11 6.5V9"></path>
			<path d="M12 9h3.5A2.5 2.5 0 1 0 13 6.5V9"></path>
		</svg>
	`,
	empresas: `
		<svg viewBox="0 0 24 24" aria-hidden="true">
			<path d="M4 21V5h10v16"></path>
			<path d="M14 10h6v11"></path>
			<path d="M8 9h2"></path>
			<path d="M8 13h2"></path>
			<path d="M8 17h2"></path>
			<path d="M17 14h1"></path>
			<path d="M17 17h1"></path>
		</svg>
	`,
};

const defaultCategoryIcon = `
	<svg viewBox="0 0 24 24" aria-hidden="true">
		<rect x="4" y="4" width="16" height="16" rx="3"></rect>
		<path d="M4 10h16"></path>
	</svg>
`;

const getCategoryIcon = (slug: string) =>
	categoryIcons[slug] || defaultCategoryIcon;
---

<header class="site-header" data-site-header>
	<div class="header-shell">
		<div class="announcement">
			<p>Grabado láser personalizado siempre gratuito</p>

			<a href={contactHref}>
				Atención personalizada
				<span aria-hidden="true">→</span>
			</a>
		</div>

		<div class="header-main">
			<div class="header-mobile-left">
				<button
					class="menu-toggle"
					type="button"
					aria-label="Abrir menú"
					aria-expanded="false"
					aria-controls="primary-navigation"
					data-menu-toggle
				>
					<span></span>
					<span></span>
					<span></span>
				</button>

				<a
					class="icon-button mobile-search-button"
					href={searchHref}
					aria-label="Buscar productos"
				>
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
					>
						<circle cx="11" cy="11" r="6.5"></circle>
						<path d="m16 16 4 4"></path>
					</svg>
				</a>
			</div>

			<a
				class="brand"
				href={homeHref}
				aria-label="TAQTO, volver al inicio"
			>
				<img
					class="brand__logo brand__logo--desktop"
					src={headerLogo}
					alt="TAQTO — Diseño con alma de madera"
					width="917"
					height="235"
				/>

				<img
					class="brand__logo brand__logo--mobile"
					src={mobileLogo}
					alt="TAQTO"
					width="511"
					height="425"
				/>
			</a>

			<nav
				id="primary-navigation"
				class="navigation"
				aria-label="Navegación principal"
				data-navigation
			>
				<ul class="navigation__list">
					<li class="navigation__item">
						<a
							class:list={[
								"navigation__link",
								{
									"is-current":
										currentPath === "/categorias/" ||
										currentPath === "/tienda/",
								},
							]}
							href={storeHref}
						>
							Tienda
						</a>
					</li>

					{
						productCategories.map((category) => {
							const categoryPath =
								`/categorias/${category.slug}/`;

							const categoryHref =
								withBase(`categorias/${category.slug}/`);

							const isCurrent =
								currentPath.startsWith(categoryPath);

							return (
								<li
									class:list={[
										"navigation__item",
										"navigation__item--dropdown",
										{ "is-current-category": isCurrent },
									]}
									data-dropdown
								>
									<div class="navigation__parent">
										<a
											class:list={[
												"navigation__link",
												{ "is-current": isCurrent },
											]}
											href={categoryHref}
										>
											<span
												class="navigation__category-icon"
												set:html={getCategoryIcon(category.slug)}
											></span>

											<span>{category.title}</span>
										</a>

										<button
											class="navigation__dropdown-toggle"
											type="button"
											aria-label={`Mostrar subcategorías de ${category.title}`}
											aria-expanded="false"
											data-dropdown-toggle
										>
											<svg
												viewBox="0 0 24 24"
												aria-hidden="true"
												fill="none"
												stroke="currentColor"
												stroke-width="1.8"
											>
												<path d="m7 9 5 5 5-5"></path>
											</svg>
										</button>
									</div>

									<div
										class="dropdown"
										data-dropdown-menu
									>
										<div class="dropdown__header">
											<span
												class="dropdown__category-icon"
												set:html={getCategoryIcon(category.slug)}
											></span>

											<div>
												<p>{category.eyebrow}</p>
												<h2>{category.title}</h2>
											</div>
										</div>

										<ul class="dropdown__links">
											{
												(category.subcategories || []).map(
													(subcategory) => (
														<li>
															<a
																href={withBase(
																	`categorias/${category.slug}/${subcategory.slug}/`,
																)}
															>
																<span>
																	{subcategory.title}
																</span>

																<svg
																	viewBox="0 0 24 24"
																	aria-hidden="true"
																	fill="none"
																	stroke="currentColor"
																	stroke-width="1.7"
																>
																	<path d="M5 12h14"></path>
																	<path d="m14 7 5 5-5 5"></path>
																</svg>
															</a>
														</li>
													),
												)
											}
										</ul>

										<a
											class="dropdown__view-all"
											href={categoryHref}
										>
											<span>Ver toda la categoría</span>
											<span aria-hidden="true">→</span>
										</a>
									</div>
								</li>
							);
						})
					}
				</ul>
			</nav>

			<div class="header-actions">
				<a
					class="icon-button desktop-search-button"
					href={searchHref}
					aria-label="Buscar productos"
				>
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
					>
						<circle cx="11" cy="11" r="6.5"></circle>
						<path d="m16 16 4 4"></path>
					</svg>
				</a>

				<a
					class="icon-button whatsapp-button"
					href={whatsappHref}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Contactar a TAQTO por WhatsApp"
				>
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.75"
					>
						<path d="M20.5 11.8a8.5 8.5 0 0 1-12.6 7.5L3.5 21l1.6-4.2a8.5 8.5 0 1 1 15.4-5Z"></path>
						<path d="M8.6 7.8c.2-.5.5-.6.8-.6h.5c.2 0 .4.1.5.4l.8 1.8c.1.3.1.5-.1.7l-.6.8c-.2.2-.2.4 0 .7.7 1.3 1.8 2.3 3.2 2.9.3.1.5.1.7-.1l.9-1.1c.2-.2.5-.3.8-.1l1.7.8c.3.1.4.4.4.7 0 .6-.3 1.5-.9 2-.7.6-1.6.8-2.6.6-1.3-.2-3-.9-4.8-2.5-1.5-1.3-2.6-2.9-3-4.1-.5-1.3-.1-2.4.3-3Z"></path>
					</svg>
				</a>

				<a
					class="icon-button account-button"
					href={accountHref}
					aria-label="Mi cuenta"
				>
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
					>
						<circle cx="12" cy="8" r="3.5"></circle>
						<path d="M5.5 20c.6-4 3-6 6.5-6s5.9 2 6.5 6"></path>
					</svg>
				</a>

				<a
					class="icon-button cart-button"
					href={cartHref}
					aria-label="Carrito, 0 productos"
					data-cart-link
				>
					<svg
						viewBox="0 0 24 24"
						aria-hidden="true"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
					>
						<path d="M5 7h14l-1 13H6L5 7Z"></path>
						<path d="M9 7V5a3 3 0 0 1 6 0v2"></path>
					</svg>

					<span class="cart-count" data-cart-count>0</span>
				</a>
			</div>
		</div>
	</div>
</header>

<script>
	import { getItemCount, onCartUpdated } from "../lib/cart";

	const updateCartBadges = () => {
		const count = getItemCount();

		const badges =
			document.querySelectorAll<HTMLElement>(
				"[data-cart-count]",
			);

		badges.forEach((badge) => {
			badge.textContent = String(count);
		});

		const cartLinks =
			document.querySelectorAll<HTMLAnchorElement>(
				"[data-cart-link]",
			);

		cartLinks.forEach((link) => {
			link.setAttribute(
				"aria-label",
				`Carrito, ${count} ${
					count === 1 ? "producto" : "productos"
				}`,
			);
		});
	};

	updateCartBadges();
	onCartUpdated(updateCartBadges);

	document.addEventListener(
		"astro:page-load",
		updateCartBadges,
	);

	const initializeHeaders = () => {
		const headers =
			document.querySelectorAll<HTMLElement>("[data-site-header]");

		headers.forEach((header) => {
			if (header.dataset.initialized === "true") return;

			header.dataset.initialized = "true";

			const menuButton =
				header.querySelector<HTMLButtonElement>("[data-menu-toggle]");

			const navigation =
				header.querySelector<HTMLElement>("[data-navigation]");

			const dropdowns = Array.from(
				header.querySelectorAll<HTMLElement>("[data-dropdown]"),
			);

			const closeDropdown = (dropdown: HTMLElement) => {
				dropdown.classList.remove("is-open");

				dropdown
					.querySelector<HTMLButtonElement>(
						"[data-dropdown-toggle]",
					)
					?.setAttribute("aria-expanded", "false");
			};

			const closeAllDropdowns = (
				exception?: HTMLElement,
			) => {
				dropdowns.forEach((dropdown) => {
					if (dropdown !== exception) {
						closeDropdown(dropdown);
					}
				});
			};

			const closeMobileMenu = () => {
				navigation?.classList.remove("is-open");

				menuButton?.setAttribute(
					"aria-expanded",
					"false",
				);

				document.body.classList.remove(
					"menu-is-open",
				);

				closeAllDropdowns();
			};

			menuButton?.addEventListener("click", () => {
				const willOpen =
					menuButton.getAttribute("aria-expanded") !==
					"true";

				menuButton.setAttribute(
					"aria-expanded",
					String(willOpen),
				);

				navigation?.classList.toggle(
					"is-open",
					willOpen,
				);

				document.body.classList.toggle(
					"menu-is-open",
					willOpen,
				);

				if (!willOpen) {
					closeAllDropdowns();
				}
			});

			dropdowns.forEach((dropdown) => {
				const toggle =
					dropdown.querySelector<HTMLButtonElement>(
						"[data-dropdown-toggle]",
					);

				let leaveTimer:
					| ReturnType<typeof setTimeout>
					| undefined;

				const openDropdown = () => {
					if (leaveTimer) {
						clearTimeout(leaveTimer);
					}

					closeAllDropdowns(dropdown);

					dropdown.classList.add("is-open");

					toggle?.setAttribute(
						"aria-expanded",
						"true",
					);
				};

				toggle?.addEventListener("click", (event) => {
					event.preventDefault();
					event.stopPropagation();

					const willOpen =
						!dropdown.classList.contains(
							"is-open",
						);

					closeAllDropdowns(dropdown);

					dropdown.classList.toggle(
						"is-open",
						willOpen,
					);

					toggle.setAttribute(
						"aria-expanded",
						String(willOpen),
					);
				});

				dropdown.addEventListener(
					"mouseenter",
					() => {
						if (window.innerWidth > 1180) {
							openDropdown();
						}
					},
				);

				dropdown.addEventListener(
					"mouseleave",
					() => {
						if (window.innerWidth > 1180) {
							leaveTimer = setTimeout(() => {
								closeDropdown(dropdown);
							}, 180);
						}
					},
				);
			});

			document.addEventListener("click", (event) => {
				if (
					event.target instanceof Node &&
					!header.contains(event.target)
				) {
					closeMobileMenu();
				}
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape") {
					closeMobileMenu();
				}
			});

			window.addEventListener("resize", () => {
				if (window.innerWidth > 1180) {
					navigation?.classList.remove("is-open");

					menuButton?.setAttribute(
						"aria-expanded",
						"false",
					);

					document.body.classList.remove(
						"menu-is-open",
					);
				}

				closeAllDropdowns();
			});
		});
	};

	initializeHeaders();

	document.addEventListener(
		"astro:page-load",
		initializeHeaders,
	);
</script>

<style>
	:global(body.menu-is-open) {
		overflow: hidden;
	}

	.site-header {
		position: sticky;
		top: 14px;
		z-index: 200;
		width: calc(100% - 28px);
		max-width: 1540px;
		margin: 14px auto 0;
		color: #fff6ed;
	}

	.header-shell {
		position: relative;
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 26px;
		background:
			linear-gradient(
				135deg,
				rgba(255, 255, 255, 0.04),
				rgba(255, 255, 255, 0.008) 46%,
				rgba(91, 49, 42, 0.025)
			),
			rgba(3, 3, 3, 0.985);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 24px 68px rgba(0, 0, 0, 0.48);
		backdrop-filter: blur(28px) saturate(115%);
		-webkit-backdrop-filter: blur(28px) saturate(115%);
	}

	.header-shell::before {
		content: "";
		position: absolute;
		top: 0;
		right: 8%;
		left: 8%;
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.35),
			transparent
		);
		pointer-events: none;
	}

	.announcement {
		min-height: 32px;
		padding: 0 28px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		color: rgba(255, 246, 237, 0.88);
		font-size: 9px;
		font-weight: 600;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.announcement p {
		margin: 0;
	}

	.announcement a {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: inherit;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.announcement a:hover {
		color: #ffffff;
	}

	.header-main {
		min-height: 80px;
		padding: 0 20px;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: clamp(18px, 2.5vw, 42px);
	}

	.header-mobile-left {
		display: none;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		color: inherit;
		text-decoration: none;
	}

	.brand__logo {
		display: block;
		height: auto;
		object-fit: contain;
	}

	.brand__logo--desktop {
		width: clamp(128px, 9vw, 158px);
		max-height: 48px;
	}

	.brand__logo--mobile {
		display: none;
		width: 42px;
		height: 42px;
	}

	.navigation {
		height: 80px;
		justify-self: center;
	}

	.navigation__list {
		height: 100%;
		display: flex;
		align-items: stretch;
		gap: clamp(6px, 1.1vw, 20px);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.navigation__item,
	.navigation__parent {
		height: 100%;
		display: flex;
		align-items: center;
	}

	.navigation__item--dropdown {
		position: relative;
	}

	.navigation__link {
		position: relative;
		height: 100%;
		display: flex;
		align-items: center;
		gap: 7px;
		padding-inline: 4px;
		color: rgba(255, 246, 237, 0.88);
		font-size: 11.5px;
		font-weight: 600;
		letter-spacing: 0.045em;
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
		transition: color 180ms ease;
	}

	.navigation__link::after {
		content: "";
		position: absolute;
		right: 4px;
		bottom: 18px;
		left: 4px;
		height: 1px;
		background: #fff6ed;
		transform: scaleX(0);
		transform-origin: right;
		transition: transform 200ms ease;
	}

	.navigation__link:hover,
	.navigation__link.is-current,
	.navigation__item.is-open .navigation__link {
		color: #ffffff;
	}

	.navigation__link:hover::after,
	.navigation__link.is-current::after,
	.navigation__item.is-open .navigation__link::after {
		transform: scaleX(1);
		transform-origin: left;
	}

	.navigation__category-icon {
		width: 20px;
		height: 20px;
		flex: 0 0 20px;
		display: grid;
		place-items: center;
		color: rgba(255, 246, 237, 0.72);
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.navigation__category-icon :global(svg) {
		width: 20px;
		height: 20px;
		display: block;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.55;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.navigation__link:hover
		.navigation__category-icon,
	.navigation__link.is-current
		.navigation__category-icon,
	.navigation__item.is-open
		.navigation__category-icon {
		color: #ffffff;
		transform: translateY(-1px);
	}

	.navigation__dropdown-toggle {
		width: 24px;
		height: 40px;
		padding: 0;
		display: grid;
		place-items: center;
		border: 0;
		background: transparent;
		color: rgba(255, 246, 237, 0.7);
		cursor: pointer;
		transition: color 180ms ease;
	}

	.navigation__dropdown-toggle:hover,
	.navigation__item.is-open
		.navigation__dropdown-toggle {
		color: #ffffff;
	}

	.navigation__dropdown-toggle svg {
		width: 14px;
		height: 14px;
		transform: rotate(0deg);
		transform-origin: center;
		transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.navigation__item.is-open
		.navigation__dropdown-toggle svg {
		transform: rotate(180deg);
	}

