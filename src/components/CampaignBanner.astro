---
interface Props {
	eyebrow?: string;
	title?: string;
	description?: string;
	buttonText?: string;
	buttonHref?: string;
	campaignId?: string;
}

const {
	eyebrow = "Edición Fiestas Patrias",
	title = "Celebremos el diseño hecho en Perú.",
	description =
		"Regala piezas de madera personalizadas con grabado láser gratuito.",
	buttonText = "Explorar regalos",
	buttonHref = "/categorias/kits-y-regalos/",
	campaignId = "fiestas-patrias-2026",
} = Astro.props;
---

<aside
	class="campaign-banner"
	data-campaign-banner
	data-campaign-id={campaignId}
	aria-label="Campaña especial de Fiestas Patrias"
>
	<div class="campaign-banner__decoration" aria-hidden="true">
		<span></span>
		<span></span>
		<span></span>
	</div>

	<div class="campaign-banner__container">
		<div class="campaign-banner__identity">
			<span class="campaign-banner__flag" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</span>

			<p class="campaign-banner__eyebrow">
				{eyebrow}
			</p>
		</div>

		<div class="campaign-banner__message">
			<h2>{title}</h2>

			<p>{description}</p>
		</div>

		<a class="campaign-banner__button" href={buttonHref}>
			<span>{buttonText}</span>

			<svg
				viewBox="0 0 24 24"
				aria-hidden="true"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
			>
				<path d="M5 12h14"></path>
				<path d="m14 7 5 5-5 5"></path>
			</svg>
		</a>

		<button
			class="campaign-banner__close"
			type="button"
			aria-label="Cerrar campaña"
			data-campaign-close
		>
			<svg
				viewBox="0 0 24 24"
				aria-hidden="true"
				fill="none"
				stroke="currentColor"
				stroke-width="1.7"
			>
				<path d="m6 6 12 12"></path>
				<path d="M18 6 6 18"></path>
			</svg>
		</button>
	</div>
</aside>

<script>
	const campaignBanners = document.querySelectorAll<HTMLElement>(
		"[data-campaign-banner]",
	);

	campaignBanners.forEach((banner) => {
		const campaignId = banner.dataset.campaignId;
		const closeButton =
			banner.querySelector<HTMLButtonElement>("[data-campaign-close]");

		if (!campaignId) return;

		const storageKey = `taqto-campaign-${campaignId}`;
		const wasClosed = sessionStorage.getItem(storageKey) === "closed";

		if (wasClosed) {
			banner.hidden = true;
			return;
		}

		closeButton?.addEventListener("click", () => {
			banner.classList.add("is-closing");

			window.setTimeout(() => {
				banner.hidden = true;
				sessionStorage.setItem(storageKey, "closed");
			}, 300);
		});
	});
</script>

<style>
	.campaign-banner {
	position: relative;
	width: 100%;
	overflow: hidden;
	background: var(--color-brown, #5b312a);
	color: var(--color-beige, #fff6ed);
	border-radius: inherit;
	box-shadow:
		0 26px 70px rgba(20, 20, 20, 0.12),
		0 4px 16px rgba(20, 20, 20, 0.06);
	transition:
		opacity 300ms ease,
		max-height 300ms ease,
		transform 300ms ease;
}

	.campaign-banner.is-closing {
		max-height: 0;
		opacity: 0;
		transform: translateY(-12px);
	}

	.campaign-banner__decoration {
		position: absolute;
		inset: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.campaign-banner__decoration span {
		position: absolute;
		border: 1px solid rgba(255, 246, 237, 0.13);
		border-radius: 50%;
	}

	.campaign-banner__decoration span:nth-child(1) {
		top: -140px;
		right: 8%;
		width: 340px;
		height: 340px;
	}

	.campaign-banner__decoration span:nth-child(2) {
		right: -80px;
		bottom: -180px;
		width: 390px;
		height: 390px;
	}

	.campaign-banner__decoration span:nth-child(3) {
		top: 28px;
		right: 22%;
		width: 150px;
		height: 150px;
		background: rgba(255, 77, 42, 0.08);
	}

	.campaign-banner__container {
		position: relative;
		z-index: 1;
		width: min(calc(100% - 80px), 1320px);
		min-height: 210px;
		margin-inline: auto;
		display: grid;
		grid-template-columns:
			minmax(180px, 0.55fr)
			minmax(420px, 1.6fr)
			auto
			40px;
		align-items: center;
		gap: clamp(28px, 4vw, 72px);
		padding-block: 34px;
	}

	.campaign-banner__identity {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.campaign-banner__flag {
		flex: 0 0 auto;
		width: 42px;
		height: 28px;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border: 1px solid rgba(255, 246, 237, 0.38);
		overflow: hidden;
	}

	.campaign-banner__flag span:nth-child(1),
	.campaign-banner__flag span:nth-child(3) {
		background: #d91023;
	}

	.campaign-banner__flag span:nth-child(2) {
		background: #ffffff;
	}

	.campaign-banner__eyebrow {
		margin: 0;
		font-size: 10px;
		font-weight: 700;
		line-height: 1.4;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.campaign-banner__message {
		max-width: 760px;
	}

	.campaign-banner__message h2 {
		margin: 0;
		font-size: clamp(32px, 4vw, 62px);
		font-weight: 600;
		line-height: 0.98;
		letter-spacing: -0.045em;
		text-wrap: balance;
	}

	.campaign-banner__message p {
		max-width: 620px;
		margin: 18px 0 0;
		font-size: clamp(14px, 1.2vw, 17px);
		line-height: 1.55;
		opacity: 0.76;
	}

	.campaign-banner__button {
		min-height: 54px;
		padding: 0 24px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 18px;
		border: 1px solid rgba(255, 246, 237, 0.65);
		background: var(--color-beige, #fff6ed);
		color: var(--color-black, #141414);
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.09em;
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
		transition:
			background-color 200ms ease,
			border-color 200ms ease,
			color 200ms ease,
			transform 200ms ease;
	}

	.campaign-banner__button svg {
		width: 19px;
		height: 19px;
		transition: transform 200ms ease;
	}

	.campaign-banner__button:hover {
		border-color: var(--color-orange, #ff4d2a);
		background: var(--color-orange, #ff4d2a);
		transform: translateY(-2px);
	}

	.campaign-banner__button:hover svg {
		transform: translateX(4px);
	}

	.campaign-banner__close {
		width: 40px;
		height: 40px;
		padding: 0;
		display: grid;
		place-items: center;
		border: 0;
		border-radius: 50%;
		background: transparent;
		color: inherit;
		cursor: pointer;
		opacity: 0.62;
		transition:
			background-color 180ms ease,
			opacity 180ms ease;
	}

	.campaign-banner__close:hover {
		background: rgba(255, 246, 237, 0.12);
		opacity: 1;
	}

	.campaign-banner__close svg {
		width: 19px;
		height: 19px;
	}

	@media (max-width: 1080px) {
		.campaign-banner__container {
			grid-template-columns: 0.45fr 1.4fr auto 40px;
			gap: 28px;
		}

		.campaign-banner__identity {
			align-items: flex-start;
			flex-direction: column;
		}
	}

	@media (max-width: 820px) {
		.campaign-banner__container {
			width: min(calc(100% - 48px), 1440px);
			min-height: 250px;
			grid-template-columns: 1fr auto;
			gap: 22px 30px;
			padding-block: 32px;
		}

		.campaign-banner__identity {
			grid-column: 1;
			align-items: center;
			flex-direction: row;
		}

		.campaign-banner__message {
			grid-column: 1 / -1;
			grid-row: 2;
		}

		.campaign-banner__button {
			grid-column: 1;
			grid-row: 3;
			justify-self: start;
		}

		.campaign-banner__close {
			grid-column: 2;
			grid-row: 1;
		}
	}

	@media (max-width: 560px) {
		.campaign-banner__container {
			width: min(calc(100% - 36px), 1440px);
			min-height: 290px;
			display: flex;
			align-items: stretch;
			flex-direction: column;
			gap: 22px;
			padding-block: 28px;
		}

		.campaign-banner__identity {
			padding-right: 48px;
		}

		.campaign-banner__message h2 {
			font-size: clamp(34px, 10vw, 48px);
		}

		.campaign-banner__button {
			width: 100%;
		}

		.campaign-banner__close {
			position: absolute;
			top: 22px;
			right: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.campaign-banner,
		.campaign-banner__button,
		.campaign-banner__button svg {
			transition: none;
		}
	}
</style>